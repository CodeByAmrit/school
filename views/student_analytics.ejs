<%- include('./partials/header.ejs', {title: "Individual Tracking: " + student.name }) %>
<%- include('./partials/topMenu.ejs') %>
<%- include('./partials/navbar.ejs') %>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js" nonce="<%= nonce %>"></script>

<div class="p-4 sm:ml-64 dark:bg-gray-900 mt-16 min-h-screen font-inter">

  <!-- ── Header Card ── -->
  <div class="mb-6">
    <a href="/search?q=&class=<%= student.class %>&session=<%= student.session %>&reason=&father_name=&mother_name=" class="text-sm text-indigo-500 hover:text-indigo-600 font-semibold flex items-center gap-2 mb-4 transition-colors">
      <i class="fas fa-arrow-left"></i> Back to Directory
    </a>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-4">
        <div class="relative w-16 h-16 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-2xl text-white font-bold shadow-lg overflow-hidden shrink-0 border-2 border-white dark:border-gray-800">
          <span class="absolute z-0 flex items-center justify-center w-full h-full pb-0.5"><%= student.name.charAt(0) %></span>
          <img src="/api/student/photo/<%= student.school_id %>" class="absolute z-10 w-full h-full object-cover fallback-hide" alt="<%= student.name %>">
        </div>
        <div>
          <h1 class="text-2xl font-black text-gray-900 dark:text-white flex items-center gap-3">
            <%= student.name %>
            <% if(student.profile_status === 'Active') { %>
              <i class="fas fa-certificate text-green-500 text-sm"></i>
            <% } %>
          </h1>
          <p class="text-gray-500 dark:text-gray-400 font-medium text-sm mt-1">
            <span class="mr-3"><i class="fas fa-graduation-cap"></i> Class: <%= student.class %></span>
            <span><i class="far fa-calendar"></i> Session: <%= student.session %></span>
          </p>
        </div>
      </div>

      <!-- KPI Badges -->
      <div class="flex flex-wrap gap-3">
        <!-- Rank -->
        <div class="px-4 py-2 bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-900/40 dark:to-amber-800/40 border border-amber-200 dark:border-amber-700/50 rounded-xl shadow-sm flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-amber-500 text-white flex items-center justify-center text-sm shadow-md">
            <i class="fas fa-trophy"></i>
          </div>
          <div>
            <p class="text-[10px] font-bold text-amber-600 dark:text-amber-400 uppercase tracking-widest leading-none">Class Rank</p>
            <p class="text-lg font-black text-amber-700 dark:text-amber-300 leading-tight">#<%= analytics.rank %> <span class="text-xs font-semibold text-amber-600/70 dark:text-amber-400/70">/ <%= analytics.totalInClass %></span></p>
          </div>
        </div>
        <!-- Ceiling -->
        <div class="px-4 py-2 bg-gradient-to-br from-indigo-50 to-indigo-100 dark:from-indigo-900/40 dark:to-indigo-800/40 border border-indigo-200 dark:border-indigo-700/50 rounded-xl shadow-sm flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-indigo-500 text-white flex items-center justify-center text-sm shadow-md">
            <i class="fas fa-chart-line"></i>
          </div>
          <div>
            <p class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest leading-none">Class Highest</p>
            <p class="text-lg font-black text-indigo-700 dark:text-indigo-300 leading-tight"><%= analytics.highestScore %>%</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Row 1: Trajectory + Grade Spectrum ── -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-6">

    <!-- Term Trajectory (wider) -->
    <div class="lg:col-span-3 bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-gray-700 flex items-center justify-center text-blue-600 dark:text-blue-400">
          <i class="fas fa-level-up-alt"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-800 dark:text-white">Term Trajectory</h3>
      </div>
      <p class="text-xs text-gray-500 mb-4 font-medium">Scoring momentum vs Class Average baseline across all terms.</p>
      <div class="relative h-72 w-full">
        <canvas id="trajectoryChart"></canvas>
      </div>
    </div>

    <!-- Grade Spectrum Doughnut (narrower) -->
    <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-gray-700 flex items-center justify-center text-green-600 dark:text-green-400">
          <i class="fas fa-th-large"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-800 dark:text-white">Grade Spectrum</h3>
      </div>
      <p class="text-xs text-gray-500 mb-4 font-medium">Distribution of subjects across performance tiers.</p>
      <div class="relative h-52 w-full flex justify-center">
        <canvas id="gradeSpectrumChart"></canvas>
      </div>
      <!-- Legend -->
      <div class="flex justify-center gap-4 mt-3 text-xs font-semibold">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-emerald-500 inline-block"></span>Distinction</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-indigo-500 inline-block"></span>Proficient</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-rose-500 inline-block"></span>Needs Work</span>
      </div>
    </div>
  </div>

  <!-- ── Row 2: Subject Mastery + Momentum ── -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

    <!-- Subject Mastery Radar -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-gray-700 flex items-center justify-center text-purple-600 dark:text-purple-400">
          <i class="fas fa-spider"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-800 dark:text-white">Subject Mastery Matrix</h3>
      </div>
      <p class="text-xs text-gray-500 mb-4 font-medium">Proficiency map across all class subjects vs cohort average.</p>
      <div class="relative h-72 w-full flex justify-center">
        <canvas id="radarChart"></canvas>
      </div>
    </div>

    <!-- Subject Momentum Bar -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-orange-50 dark:bg-gray-700 flex items-center justify-center text-orange-500 dark:text-orange-400">
          <i class="fas fa-exchange-alt fa-rotate-90"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-800 dark:text-white">Subject Momentum</h3>
      </div>
      <p class="text-xs text-gray-500 mb-4 font-medium">Delta between first & latest term — green = improving, red = declining.</p>
      <div id="momentumEmpty" class="hidden text-center text-gray-400 text-sm py-16">
        <i class="fas fa-info-circle mb-2 text-2xl"></i>
        <p>At least 2 terms required for momentum analysis.</p>
      </div>
      <div class="relative h-72 w-full">
        <canvas id="momentumChart"></canvas>
      </div>
    </div>

  </div>
</div>

<!-- ── Charts JS ── -->
<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', function () {
    const data = <%- JSON.stringify(analytics) %>;

    // ── 1. Term Trajectory ──────────────────────────────────────
    const termsSet = new Set([
      ...data.personalTrend.map(t => t.term),
      ...data.classTrend.map(t => t.term)
    ]);
    const terms = Array.from(termsSet).sort((a, b) => a - b);

    const personalValues = terms.map(t => {
      const p = data.personalTrend.find(x => x.term === t);
      return p ? parseFloat(p.percentage).toFixed(2) : null;
    });
    const classValues = terms.map(t => {
      const c = data.classTrend.find(x => x.term === t);
      return c ? parseFloat(c.avg_percentage).toFixed(2) : null;
    });

    new Chart(document.getElementById('trajectoryChart').getContext('2d'), {
      type: 'line',
      data: {
        labels: terms.map(t => 'Term ' + t),
        datasets: [
          {
            label: '<%- student.name %>',
            data: personalValues,
            borderColor: '#4f46e5',
            backgroundColor: 'rgba(79,70,229,0.1)',
            borderWidth: 3, fill: true, tension: 0.35,
            pointRadius: 5, pointHoverRadius: 8
          },
          {
            label: 'Class Average',
            data: classValues,
            borderColor: '#94a3b8',
            backgroundColor: 'transparent',
            borderWidth: 2, borderDash: [5, 5],
            fill: false, tension: 0.35,
            pointRadius: 0, pointHoverRadius: 0
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          y: { suggestedMin: 0, max: 100, grid: { borderDash: [4, 4] } },
          x: { grid: { display: false } }
        },
        plugins: {
          legend: { position: 'top' },
          tooltip: {
            mode: 'index', intersect: false,
            backgroundColor: '#1e293b', titleColor: '#fff',
            cornerRadius: 8, padding: 12
          }
        }
      }
    });

    // ── 2. Grade Spectrum Doughnut ──────────────────────────────
    let distinction = 0, proficient = 0, needsWork = 0;
    data.subjectRadar.forEach(s => {
      const avg = parseFloat(s.student_subject_avg) || 0;
      if (avg >= 90) distinction++;
      else if (avg >= 60) proficient++;
      else needsWork++;
    });

    new Chart(document.getElementById('gradeSpectrumChart').getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: ['Distinction (≥90%)', 'Proficient (60-89%)', 'Needs Work (<60%)'],
        datasets: [{
          data: [distinction, proficient, needsWork],
          backgroundColor: ['#10b981', '#6366f1', '#f43f5e'],
          hoverBackgroundColor: ['#059669', '#4f46e5', '#e11d48'],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ` ${ctx.label}: ${ctx.raw} subject${ctx.raw !== 1 ? 's' : ''}`
            },
            backgroundColor: '#1e293b', titleColor: '#fff',
            cornerRadius: 8, padding: 10
          }
        }
      }
    });

    // ── 3. Subject Mastery Radar ────────────────────────────────
    const subjects = data.subjectRadar.map(s => s.subject);
    const studentRadar = data.subjectRadar.map(s => parseFloat(s.student_subject_avg).toFixed(2));
    const classRadar   = data.subjectRadar.map(s => parseFloat(s.class_subject_avg).toFixed(2));

    new Chart(document.getElementById('radarChart').getContext('2d'), {
      type: 'radar',
      data: {
        labels: subjects,
        datasets: [
          {
            label: '<%- student.name %>',
            data: studentRadar,
            backgroundColor: 'rgba(168,85,247,0.2)',
            borderColor: '#a855f7',
            pointBackgroundColor: '#a855f7',
            pointBorderColor: '#fff',
            borderWidth: 2
          },
          {
            label: 'Class Average',
            data: classRadar,
            backgroundColor: 'rgba(148,163,184,0.1)',
            borderColor: '#94a3b8',
            pointBackgroundColor: '#94a3b8',
            pointBorderColor: '#fff',
            borderDash: [4, 4],
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          r: {
            angleLines: { color: 'rgba(0,0,0,0.08)' },
            grid: { color: 'rgba(0,0,0,0.08)' },
            suggestedMin: 0, suggestedMax: 100,
            ticks: { display: false }
          }
        },
        plugins: { legend: { position: 'bottom' } }
      }
    });

    // ── 4. Subject Momentum Bar ─────────────────────────────────
    const momentum = data.subjectMomentum;
    if (!momentum || momentum.length === 0) {
      document.getElementById('momentumEmpty').classList.remove('hidden');
      document.getElementById('momentumChart').style.display = 'none';
    } else {
      const momLabels = momentum.map(m => m.subject);
      const momDeltas = momentum.map(m => {
        const latest = parseFloat(m.latest_pct) || 0;
        const first  = parseFloat(m.first_pct) || 0;
        return parseFloat((latest - first).toFixed(2));
      });
      const momColors = momDeltas.map(d => d >= 0 ? 'rgba(16,185,129,0.85)' : 'rgba(244,63,94,0.85)');

      new Chart(document.getElementById('momentumChart').getContext('2d'), {
        type: 'bar',
        data: {
          labels: momLabels,
          datasets: [{
            label: 'Score Change (%)',
            data: momDeltas,
            backgroundColor: momColors,
            borderRadius: 6,
            borderSkipped: false
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true, maintainAspectRatio: false,
          scales: {
            x: {
              grid: { borderDash: [4, 4] },
              ticks: {
                callback: v => (v > 0 ? '+' : '') + v + '%'
              }
            },
            y: { grid: { display: false } }
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => {
                  const v = ctx.raw;
                  return ` ${v > 0 ? '▲ +' : '▼ '}${v}% vs Term 1`;
                }
              },
              backgroundColor: '#1e293b', titleColor: '#fff',
              cornerRadius: 8, padding: 10
            }
          }
        }
      });
    }

  });
</script>

<%- include('./partials/bottonNavBar.ejs') %>
<%- include('./partials/footer.ejs') %>
