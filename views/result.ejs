<%- include('partials/land_header') %>

<main class="bg-gray-50/50">
  <div class="relative py-12 text-white bg-white no-print">
    <img
      src="/image/school-bg.svg"
      alt="Schools"
      class="absolute w-full h-[350px] hidden sm:hidden md:inline z-10 -rotate-3"
    />
    <div
      class="absolute inset-0 z-0 transform -skew-y-3 bg-gradient-to-br from-[#63b3ed] to-[#3182ce] py-20 h-[420px] -top-10"
    ></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
          Student Academic Report
        </h1>
        <p class="text-lg opacity-90">
          View and download your term-wise performance.
        </p>
      </div>
    </div>
  </div>

  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 -mt-20 relative z-20"
  >
    <% if (error) { %>
    <div
      class="bg-white rounded-2xl shadow-lg border border-red-100 p-8 text-center"
    >
      <div
        class="w-20 h-20 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4"
      >
        <i class="fas fa-exclamation-triangle text-red-500 text-4xl"></i>
      </div>
      <h2 class="text-2xl font-bold text-red-800 mb-2">Result Not Found</h2>
      <p class="text-red-600 mb-6"><%= error %></p>
      <a
        href="/#result-lookup"
        class="text-blue-600 hover:underline font-medium"
      >
        <i class="fas fa-arrow-left mr-2"></i>
        Go Back and Try Again
      </a>
    </div>
    <% } else if (student) { %>
    <!-- Result Card -->
    <div
      class="bg-white rounded-2xl shadow-lg border border-blue-100 overflow-hidden printable-result"
    >
      <!-- Header -->
      <div
        class="p-4 md:p-6 bg-gradient-to-r bg-blue-50 border-b border-blue-100"
      >
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-4"
        >
          <div class="flex items-center gap-5">
            <% if (school && school.school_logo) { %>
            <img
              class="h-20 w-20 rounded-full object-cover border-4 border-white shadow-md"
              src="data:image/png;base64,<%= school.school_logo.toString('base64') %>"
              alt="School Logo"
            />
            <% } else { %>
            <div
              class="h-20 w-20 rounded-full bg-blue-100 flex items-center justify-center border-4 border-white shadow-md"
            >
              <i class="fas fa-school text-blue-500 text-3xl"></i>
            </div>
            <% } %>
            <div>
              <h2 class="text-2xl font-bold text-gray-900">
                <%= school ? school.school_name : 'School Name' %>
              </h2>
              <p class="text-gray-600">
                <%= school ? school.school_address : 'School Address' %>
              </p>
            </div>
          </div>
          <div class="text-center md:text-right">
            <button
              id="print-button"
              class="inline-flex items-center bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:from-[#3182ce] hover:to-[#63b3ed] text-white px-6 py-3 rounded-lg font-medium transition-all duration-300 shadow-md hover:shadow-lg no-print"
            >
              <i class="fas fa-print mr-2"></i>
              Print Result
            </button>
          </div>
        </div>
      </div>
      <!-- Student Info -->
      <div
        class="p-4 md:p-6 grid grid-cols-2 md:grid-cols-4 gap-4 border-b border-blue-100"
      >
        <div>
          <label class="block text-sm text-gray-500">Student Name</label>
          <p class="font-semibold text-gray-800"><%= student.name %></p>
        </div>
        <div>
          <label class="block text-sm text-gray-500">Father's Name</label>
          <p class="font-semibold text-gray-800"><%= student.father_name %></p>
        </div>
        <div>
          <label class="block text-sm text-gray-500">Class</label>
          <p class="font-semibold text-gray-800"><%= student.class %></p>
        </div>
        <div>
          <label class="block text-sm text-gray-500">Roll No.</label>
          <p class="font-semibold text-gray-800"><%= student.roll %></p>
        </div>
        <div>
          <label class="block text-sm text-gray-500">Session</label>
          <p class="font-semibold text-gray-800"><%= student.session %></p>
        </div>
        <div>
          <label class="block text-sm text-gray-500">Date of Birth</label>
          <p class="font-semibold text-gray-800"><%= student.dob %></p>
        </div>
      </div>

      <!-- Consolidated Marks Table -->
      <div class="p-4 md:p-6">
        <% const subjectsData = {}; const termHeaders = new Set(); if (marks) {
        marks.forEach(mark => { termHeaders.add(mark.term); if
        (!subjectsData[mark.subject]) { subjectsData[mark.subject] = {
        max_marks: mark.max_marks }; } subjectsData[mark.subject][mark.term] =
        mark.marks; }); } const sortedTermHeaders =
        Array.from(termHeaders).sort((a, b) => a - b); %>
        <h3 class="text-xl font-bold text-gray-800 mb-4 pb-2">
          Academic Performance
        </h3>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 text-gray-600 uppercase">
              <tr>
                <th class="px-4 py-2">Subject</th>
                <% sortedTermHeaders.forEach(term => { %>
                <th class="px-4 py-2 text-center">Term <%= term %></th>
                <% }); %>
                <th class="px-4 py-2 text-center">Max Marks</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% Object.keys(subjectsData).sort().forEach(subject => { %>
              <tr>
                <td class="px-4 py-3 font-medium text-gray-900">
                  <%= subject %>
                </td>
                <% sortedTermHeaders.forEach(term => { %>
                <td class="px-4 py-3 text-center">
                  <%= subjectsData[subject][term] || '-' %>
                </td>
                <% }); %>
                <td class="px-4 py-3 text-center">
                  <%= subjectsData[subject].max_marks || '100' %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Performance Summary Table -->
      <% if (sortedTermHeaders.length > 0) { %>
      <div class="p-4 md:p-6 border-t border-blue-100">
        <h3 class="text-xl font-bold text-gray-800 mb-4 pb-1">
          Academic Summary
        </h3>
        <div class="overflow-x-auto border border-gray-200 rounded-lg">
          <table class="w-full text-sm text-left border-collapse">
            <thead class="bg-blue-50 text-blue-900 uppercase font-bold">
              <tr>
                <th class="px-4 py-2 border">Term</th>
                <th class="px-4 py-2 border text-center">Total Marks</th>
                <th class="px-4 py-2 border text-center">Percentage</th>
                <th class="px-4 py-2 border text-center">Grade</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% sortedTermHeaders.forEach(term => { %> <% const termPerformance =
              performance.find(p => p.term == term); %> <% const termGrade =
              grades.find(g => g.term == term); %>
              <tr>
                <td class="px-4 py-2 border font-medium text-gray-900">
                  Term <%= term %>
                </td>
                <td class="px-4 py-2 border text-center text-gray-700">
                  <%= termPerformance ? termPerformance.grand_total + ' / ' +
                  termPerformance.total_max_marks : '-' %>
                </td>
                <td class="px-4 py-2 border text-center text-gray-700">
                  <%= (termPerformance && termPerformance.percentage) ?
                  Number(termPerformance.percentage).toFixed(2) + '%' : 'N/A' %>
                </td>
                <td class="px-4 py-2 border text-center">
                  <span
                    class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-800 font-semibold"
                    ><%= termGrade ? termGrade.grade : '-' %></span
                  >
                </td>
              </tr>
              <% }); %>
            </tbody>
            <% if (overallStatus) { %>
            <tfoot class="bg-gray-50 border-t-2 border-gray-200">
              <tr>
                <td colspan="2" class="px-4 py-2 border text-right font-bold text-gray-600">Total Attendance:</td>
                <td colspan="2" class="px-4 py-2 border text-left font-bold text-blue-700">
                  <%= overallStatus.attendance %>
                </td>
              </tr>
              <tr class="bg-blue-50/30">
                <td colspan="2" class="px-4 py-3 border text-right font-bold text-gray-700 uppercase tracking-wider">Overall Status:</td>
                <td colspan="2" class="px-4 py-3 border text-left font-black text-xl <%= overallStatus.status === 'passed' || overallStatus.status === 'promoted' ? 'text-green-600' : 'text-red-600' %> uppercase">
                  <%= overallStatus.status %>
                </td>
              </tr>
            </tfoot>
            <% } %>
          </table>
        </div>
      </div>
      <% } %>
    </div>

    <% } else { %>
    <div
      class="bg-white rounded-2xl shadow-lg border border-blue-100 p-8 text-center"
    >
      <div
        class="w-20 h-20 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4"
      >
        <i class="fas fa-search text-blue-500 text-4xl"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Find Your Result</h2>
      <p class="text-gray-600 mb-8">
        Please enter your credentials to view your academic report.
      </p>
      <form action="/result" method="POST" class="max-w-sm mx-auto">
        <div class="space-y-4 mb-6">
          <div>
            <label for="roll" class="sr-only">Roll Number</label>
            <input
              type="text"
              name="roll"
              id="roll"
              required=""
              placeholder="Roll Number"
              class="block w-full px-4 py-3 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 transition"
            />
          </div>
          <div>
            <label for="dob" class="sr-only">Date of Birth</label>
            <input
              type="text"
              name="dob"
              id="dob"
              required
              placeholder="DD-MM-YYYY"
              class="block w-full px-4 py-3 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 transition text-center"
            />
          </div>
        </div>
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:from-[#3182ce] hover:to-[#63b3ed] text-white px-8 py-3 rounded-lg font-medium transition-all duration-300 shadow-md hover:shadow-lg"
        >
          View Result
        </button>
      </form>
    </div>
    <% } %>
  </div>
</main>

<%- include('partials/land_footer') %>

<style>
  @media print {
    @page {
      size: A4;
      margin: 2mm;
    }
    body {
      margin: 0 !important;
      padding: 0 !important;
      background: #fff !important;
      -webkit-print-color-adjust: exact;
    }
    .no-print,
    header,
    footer,
    nav {
      display: none !important;
    }
    main {
      padding: 0 !important;
      margin: 0 !important;
      display: block !important;
    }
    .relative.py-12.text-white {
      display: none !important;
    }
    .max-w-5xl {
      max-width: none !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    .printable-result {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      border: none !important;
      box-shadow: none !important;
      transform: scale(0.9);
      transform-origin: top center;
      margin: 0 !important;
      padding: 0 !important;
    }
    .-mt-20 {
      margin-top: 0 !important;
    }
    /* Compact further in print */
    .p-4, .p-6, .p-8 {
      padding: 8px !important;
    }
    h1, h2, h3 {
      margin-top: 4px !important;
      margin-bottom: 4px !important;
    }
  }
</style>

<script nonce="<%= nonce %>">
  document.addEventListener("DOMContentLoaded", function () {
    const printButton = document.getElementById("print-button");
    if (printButton) {
      printButton.addEventListener("click", function () {
        window.print();
      });
    }
  });
</script>
