<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile - StudentTracker</title>

    <!-- Preconnect for faster CDN load -->
    <link
      rel="preconnect"
      href="https://cdnjs.cloudflare.com"
      crossorigin
      nonce="<%= nonce %>"
    />

    <!-- Compiled CSS -->
    <link rel="stylesheet" href="/css/styles.css?v=<%= appVersion %>" nonce="<%= nonce %>" />
    <!-- Font Awesome 6 (Free) -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />

    <!-- Critical inline styles for smooth loading and typography refinement -->
    <style nonce="<%= nonce %>">
      /* Prevent FOUC */
      body {
        visibility: hidden;
      }
      body.ready {
        visibility: visible;
      }

      /* Refined scrollbar */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 8px;
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #63b3ed, #3182ce);
        border-radius: 8px;
      }

      /* Subtle fade-in animation */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-in {
        animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
      }

      /* Smooth card hover */
      .card-hover {
        transition: all 0.3s ease;
      }
      .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.1);
      }

      /* Focus ring for accessibility */
      *:focus-visible {
        outline: 2px solid #3182ce;
        outline-offset: 2px;
        border-radius: 0.5rem;
      }

      /* Typography scale */
      h1, h2, h3, h4, .heading {
        letter-spacing: -0.02em;
      }
      body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: linear-gradient(145deg, #f8fafc 0%, #eef2f6 100%);
      }
    </style>
  </head>

  <body class="min-h-screen antialiased">
    <div class="min-h-screen fade-in">
      <!-- Premium Header with subtle pattern -->
      <div class="relative bg-gradient-to-br from-[#1e5eb0] via-[#3182ce] to-[#4299e1] overflow-hidden">
        <!-- Abstract pattern overlay -->
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M30 0 L60 30 L30 60 L0 30 Z" fill="none" stroke="white" stroke-width="1.5"/%3E%3C/svg%3E'); background-size: 30px 30px;"></div>
        <div class="relative max-w-7xl mx-auto px-6 py-10 md:py-12 lg:py-16">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
              <a href="/dashboard" class="inline-flex items-center text-white/80 hover:text-white transition-colors mb-3 text-sm font-medium">
                <i class="fas fa-arrow-left mr-2 text-xs"></i> Back to Dashboard
              </a>
              <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-white">My Profile</h1>
              <p class="text-white/80 text-base md:text-lg mt-2 max-w-xl">Manage your personal and school information securely</p>
            </div>
            <div class="flex items-center gap-5">
              <div class="text-right hidden sm:block">
                <p class="text-sm font-medium text-white/80">Account Status</p>
                <p class="text-xl font-bold text-white flex items-center justify-end gap-2"><span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span></span> Active</p>
              </div>
              <div class="w-14 h-14 rounded-2xl bg-white/10 backdrop-blur-sm border border-white/30 flex items-center justify-center shadow-lg">
                <i class="fas fa-user-graduate text-white text-2xl"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Left Column: Profile & Edit Form -->
          <div class="lg:col-span-2 space-y-8">
            <!-- Profile Display Card -->
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden transition-all duration-300 card-hover">
              <div class="bg-white px-6 pt-6 pb-4 border-b border-gray-100 flex flex-wrap items-center justify-between gap-4">
                <div>
                  <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Personal Information</h2>
                  <p class="text-gray-500 text-sm mt-1">Your identity and contact details</p>
                </div>
                <button id="editProfileBtn" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 text-white text-sm font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200">
                  <i class="fas fa-pen-alt text-xs"></i> Edit Profile
                </button>
              </div>

              <div class="p-6 md:p-8">
                <div class="flex flex-col lg:flex-row gap-8">
                  <!-- Avatar / Logo Section -->
                  <div class="lg:w-1/3 flex flex-col items-center">
                    <div class="relative">
                      <div class="w-40 h-40 rounded-2xl overflow-hidden bg-gradient-to-br from-blue-50 to-indigo-50 shadow-xl border-4 border-white">
                        <% if (base64Image) { %>
                          <img src="<%= base64Image %>" alt="School Logo" class="w-full h-full object-cover" />
                        <% } else { %>
                          <div class="w-full h-full flex items-center justify-center">
                            <i class="fas fa-school text-blue-300 text-6xl"></i>
                          </div>
                        <% } %>
                      </div>
                      <div class="absolute -bottom-2 -right-2 w-10 h-10 rounded-full bg-gradient-to-tr from-green-400 to-green-500 flex items-center justify-center shadow-lg border-2 border-white">
                        <i class="fas fa-check text-white text-sm"></i>
                      </div>
                    </div>
                    <div class="mt-5 text-center">
                      <label for="logo-upload" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 text-gray-700 text-sm font-medium rounded-xl border border-gray-200 cursor-pointer transition-all">
                        <i class="fas fa-cloud-upload-alt text-blue-500"></i> Change Logo
                      </label>
                      <input id="logo-upload" type="file" accept="image/*" class="hidden" />
                      <p class="text-xs text-gray-400 mt-2">PNG, JPG up to 2MB</p>
                    </div>
                  </div>

                  <!-- Profile Details -->
                  <div class="lg:w-2/3">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                      <div class="space-y-1">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Full Name</p>
                        <p class="text-lg font-bold text-gray-900" id="displayName"><%= teacher.first_name.toUpperCase() %> <%= teacher.last_name.toUpperCase() %></p>
                      </div>
                      <div class="space-y-1">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Email Address</p>
                        <p class="text-lg font-bold text-gray-900" id="displayEmail"><%= teacher.email %></p>
                      </div>
                      <div class="space-y-1">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">School Name</p>
                        <p class="text-lg font-bold text-gray-900" id="displaySchool"><%= teacher.school_name.toUpperCase() %></p>
                      </div>
                      <div class="space-y-1">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Phone Number</p>
                        <p class="text-lg font-bold text-gray-900" id="displayPhone"><%= teacher.school_phone || 'Not provided' %></p>
                      </div>
                      <div class="sm:col-span-2 space-y-1">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">School Address</p>
                        <p class="text-lg font-bold text-gray-900" id="displayAddress"><%= teacher.school_address.toUpperCase() %></p>
                      </div>
                    </div>

                    <!-- Account Summary -->
                    <div class="mt-8 pt-6 border-t border-gray-100">
                      <h3 class="text-lg font-bold text-gray-900 mb-4">Account Overview</h3>
                      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-4 border border-blue-100">
                          <p class="text-xs font-semibold text-blue-600 uppercase">Role</p>
                          <p class="text-lg font-bold text-gray-800">Teacher</p>
                        </div>
                        <div class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-4 border border-blue-100">
                          <p class="text-xs font-semibold text-blue-600 uppercase">Member Since</p>
                          <p class="text-lg font-bold text-gray-800" id="memberSince"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short' }) %></p>
                        </div>
                        <div class="bg-gradient-to-br from-green-50 to-white rounded-xl p-4 border border-green-100">
                          <p class="text-xs font-semibold text-green-600 uppercase">Status</p>
                          <div class="flex items-center gap-2">
                            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span></span>
                            <p class="text-lg font-bold text-green-700">Active</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Edit Form (Initially Hidden) -->
            <form id="editProfileForm" action="/teacher/profile/update/<%= teacher.id %>" method="POST" enctype="multipart/form-data" class="hidden bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden transition-all duration-300">
              <div class="bg-gray-50 px-6 py-5 border-b border-gray-100">
                <h2 class="text-2xl font-bold text-gray-900">Edit Profile</h2>
                <p class="text-gray-500 text-sm mt-1">Update your details below</p>
              </div>
              <div class="p-6 md:p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-user text-blue-500 mr-2"></i>First Name</label>
                    <input type="text" id="first_name" name="first_name" value="<%= teacher.first_name %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all uppercase">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-user text-blue-500 mr-2"></i>Last Name</label>
                    <input type="text" id="last_name" name="last_name" value="<%= teacher.last_name %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all uppercase">
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-envelope text-blue-500 mr-2"></i>Email Address</label>
                  <input type="email" id="email" name="email" value="<%= teacher.email %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all">
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-school text-blue-500 mr-2"></i>School Name</label>
                  <input type="text" id="school_name" name="school_name" value="<%= teacher.school_name %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all uppercase">
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-image text-blue-500 mr-2"></i>School Logo</label>
                  <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-dashed border-gray-300 rounded-2xl hover:border-blue-400 transition bg-gray-50/50">
                    <div class="space-y-1 text-center">
                      <i class="fas fa-cloud-upload-alt text-3xl text-blue-400"></i>
                      <div class="flex text-sm text-gray-600 justify-center">
                        <label for="school_logo" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500">Upload a file</label>
                        <p class="pl-1">or drag and drop</p>
                      </div>
                      <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
                      <input id="school_logo" name="school_logo" type="file" class="sr-only" accept="image/*">
                    </div>
                  </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-map-marker-alt text-blue-500 mr-2"></i>School Address</label>
                    <input type="text" id="school_address" name="school_address" value="<%= teacher.school_address %>" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all uppercase">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2"><i class="fas fa-phone text-blue-500 mr-2"></i>School Phone</label>
                    <input type="text" id="school_phone" name="school_phone" value="<%= teacher.school_phone %>" placeholder="xxx xxx xxxx" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-300 focus:border-blue-300 transition-all">
                  </div>
                </div>
                <div class="flex flex-col sm:flex-row gap-4 pt-4 border-t border-gray-100">
                  <button type="submit" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 text-white font-bold rounded-xl shadow-md hover:shadow-lg transition-all">
                    <i class="fas fa-check-circle"></i> Save Changes
                  </button>
                  <button type="button" id="cancelEditBtn" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-white border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-all">
                    Cancel
                  </button>
                </div>
              </div>
            </form>
          </div>

          <!-- Right Column: Security, Stats, Support -->
          <div class="space-y-7">
            <!-- Security Card -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 card-hover">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center"><i class="fas fa-shield-alt text-blue-600"></i></div>
                <h3 class="text-xl font-bold text-gray-900">Security</h3>
              </div>
              <div class="space-y-4">
                <a href="/change-password" class="flex items-center gap-4 p-3 rounded-xl bg-gray-50 hover:bg-gray-100 transition-colors group">
                  <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center"><i class="fas fa-key text-blue-600"></i></div>
                  <div class="flex-1">
                    <p class="font-semibold text-gray-800 group-hover:text-blue-600">Change Password</p>
                    <p class="text-xs text-gray-500">Update your password regularly</p>
                  </div>
                  <i class="fas fa-chevron-right text-gray-400 text-sm"></i>
                </a>
                <div class="flex items-center gap-4 p-3 rounded-xl bg-green-50 border border-green-100">
                  <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center"><i class="fas fa-check-circle text-green-600"></i></div>
                  <div>
                    <p class="font-semibold text-gray-800">2FA Status</p>
                    <p class="text-xs text-green-700 font-medium">Active & Secure</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Stats Card -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 card-hover">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center"><i class="fas fa-chart-simple text-blue-600"></i></div>
                <h3 class="text-xl font-bold text-gray-900">Profile Insights</h3>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                  <span class="text-gray-600 font-medium">Completion</span>
                  <div class="flex items-center gap-3">
                    <div class="w-28 h-2 bg-gray-200 rounded-full overflow-hidden"><div class="h-full bg-gradient-to-r from-blue-500 to-blue-600 rounded-full" style="width: 85%"></div></div>
                    <span class="text-sm font-bold text-blue-600">85%</span>
                  </div>
                </div>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                  <span class="text-gray-600 font-medium">Last Updated</span>
                  <span class="font-semibold text-green-600">Today</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                  <span class="text-gray-600 font-medium">Profile Views</span>
                  <span class="font-semibold text-purple-600">124</span>
                </div>
              </div>
            </div>

            <!-- Support Card - Premium Gradient -->
            <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 p-6 text-white shadow-xl card-hover">
              <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
              <div class="relative">
                <div class="flex items-center gap-3 mb-4">
                  <i class="fas fa-headset text-2xl"></i>
                  <h3 class="text-xl font-bold">Need Help?</h3>
                </div>
                <p class="text-white/80 text-sm mb-6">We're here 24/7 to assist you with any questions.</p>
                <div class="space-y-3">
                  <a href="mailto:support@studenttracker.com" class="flex items-center gap-3 p-3 bg-white/10 rounded-xl hover:bg-white/20 transition-all">
                    <i class="fas fa-envelope"></i> Email Support
                  </a>
                  <a href="/help" class="flex items-center gap-3 p-3 bg-white/10 rounded-xl hover:bg-white/20 transition-all">
                    <i class="fas fa-life-ring"></i> Help Center
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Success Toast Notification -->
    <div id="successToast" class="hidden fixed bottom-6 right-6 max-w-sm bg-white rounded-xl shadow-2xl border-l-4 border-green-500 p-4 z-50 animate-fade-in-up">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center"><i class="fas fa-check text-green-600"></i></div>
        <div class="flex-1">
          <p class="font-bold text-gray-800">Success!</p>
          <p class="text-sm text-gray-600">Profile updated successfully</p>
        </div>
        <button id="closeToastBtn" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
      </div>
    </div>

    <!-- Scripts -->
    <script src="/js/user_profile.js?v=<%= appVersion %>" nonce="<%= nonce %>" defer></script>
    <!-- Additional inline script for form toggle and logo preview (nonce-aware) -->
    <script nonce="<%= nonce %>">
      (function() {
        // Toggle between display and edit mode
        const editBtn = document.getElementById('editProfileBtn');
        const displayCard = document.querySelector('.bg-white.rounded-2xl.shadow-xl.border.border-gray-100.overflow-hidden');
        const editForm = document.getElementById('editProfileForm');
        const cancelBtn = document.getElementById('cancelEditBtn');

        if (editBtn && displayCard && editForm && cancelBtn) {
          editBtn.addEventListener('click', () => {
            displayCard.classList.add('hidden');
            editForm.classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          cancelBtn.addEventListener('click', () => {
            editForm.classList.add('hidden');
            displayCard.classList.remove('hidden');
          });
        }

        // Logo upload preview (for the display card)
        const logoInput = document.getElementById('logo-upload');
        if (logoInput) {
          logoInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file && file.type.startsWith('image/')) {
              const reader = new FileReader();
              reader.onload = function(ev) {
                const imgContainer = document.querySelector('.w-40.h-40.rounded-2xl.overflow-hidden');
                if (imgContainer) {
                  imgContainer.innerHTML = `<img src="${ev.target.result}" alt="School Logo" class="w-full h-full object-cover" />`;
                }
              };
              reader.readAsDataURL(file);
            }
          });
        }

        // Show toast on successful update (if query param or flash message)
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('updated') === 'true') {
          const toast = document.getElementById('successToast');
          if (toast) {
            toast.classList.remove('hidden');
            // Add listener to close button
            const closeBtn = document.getElementById('closeToastBtn');
            if (closeBtn) {
              closeBtn.addEventListener('click', () => {
                toast.classList.add('hidden');
              });
            }
            setTimeout(() => {
              toast.classList.add('hidden');
            }, 4000);
          }
        }

        // Mark body ready
        document.body.classList.add('ready');
      })();
    </script>
    <style nonce="<%= nonce %>">
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in-up {
        animation: fade-in-up 0.3s ease-out;
      }
    </style>
  </body>
</html>