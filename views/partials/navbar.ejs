<aside
  id="logo-sidebar"
  class="fixed top-0 left-0 z-40 w-64 h-screen transition-transform -translate-x-full sm:translate-x-0 bg-gradient-to-b from-blue-50 to-white dark:from-gray-900 dark:to-gray-800 border-r border-blue-100 dark:border-gray-800"
  aria-label="Sidebar"
>
  <!-- Logo Section -->
  <div
    class="px-4 py-4 flex justify-center items-center border-b border-blue-100 dark:border-gray-800 bg-white dark:bg-gray-800"
  >
    <a href="/" class="flex items-center">
      <span
        class="self-center text-xl font-bold bg-gradient-to-r from-[#63b3ed] to-[#3182ce] bg-clip-text text-transparent whitespace-nowrap"
        >StudentTracker</span
      >
    </a>
  </div>

  <div
    class="h-full px-3 pb-4 overflow-y-auto bg-gradient-to-t from-blue-50 to-white dark:from-gray-900 dark:to-gray-800"
  >
    <!-- Add New Student Button -->
    <div class="px-2 pt-4 pb-3">
      <a
        href="/student/new"
        class="group relative flex items-center justify-center gap-3 w-full px-4 py-3 text-sm font-medium text-white rounded-xl bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:from-[#3182ce] hover:to-[#63b3ed] transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-[1.02] transform"
      >
        <!-- Animated Plus Icon -->
        <div class="relative">
          <div
            class="absolute -inset-2 bg-white/20 rounded-full group-hover:scale-110 transition-transform duration-300"
          ></div>
          <i
            class="fas fa-user-plus flex items-center justify-center text-base relative z-10"
          ></i>
        </div>
        <span class="leading-none font-semibold">Add New Student</span>
      </a>
    </div>

    <!-- Main Navigation -->
    <ul class="space-y-1 font-medium">
      <li>
        <a
          href="/dashboard"
          class="group relative flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gradient-to-r hover:from-blue-50 hover:to-white dark:hover:from-gray-800 dark:hover:to-gray-700 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300"
        >
          <!-- Active Indicator -->
          <div
            class="absolute left-0 w-1 h-6 bg-[#3182ce] rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          ></div>

          <!-- Icon Container -->
          <div
            class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-100 to-white dark:from-gray-800 dark:to-gray-900 border border-blue-200 dark:border-gray-700 flex items-center justify-center mr-3 group-hover:bg-gradient-to-br group-hover:from-blue-200 group-hover:to-blue-100 dark:group-hover:from-gray-700 dark:group-hover:to-gray-800 transition-all duration-300"
          >
            <i class="fas fa-chart-pie text-blue-600 text-sm"></i>
          </div>

          <span class="font-medium">Dashboard</span>

          <!-- Hover Indicator -->
          <i
            class="fas fa-chevron-right text-blue-400 ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300"
          ></i>
        </a>
      </li>

      <li>
        <a
          href="/students"
          class="group relative flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gradient-to-r hover:from-blue-50 hover:to-white dark:hover:from-gray-800 dark:hover:to-gray-700 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300"
        >
          <!-- Active Indicator -->
          <div
            class="absolute left-0 w-1 h-6 bg-[#3182ce] rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          ></div>

          <!-- Icon Container -->
          <div class="relative">
            <div
              class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-100 to-white dark:from-gray-800 dark:to-gray-900 border border-blue-200 dark:border-gray-700 flex items-center justify-center mr-3 group-hover:bg-gradient-to-br group-hover:from-blue-200 group-hover:to-blue-100 dark:group-hover:from-gray-700 dark:group-hover:to-gray-800 transition-all duration-300"
            >
              <i class="fa-solid fa-user text-blue-600 text-sm"></i>
            </div>
            <!-- Notification Badge -->
            <div
              class="absolute -top-1 -right-1 w-6 h-6 rounded-full bg-gradient-to-br from-[#63b3ed] to-[#3182ce] flex items-center justify-center shadow-md"
            >
              <span class="text-xs font-bold text-white">
                <%= total_students || 0 %>
              </span>
            </div>
          </div>

          <span class="font-medium">All Students</span>

          <!-- Hover Indicator -->
          <i
            class="fas fa-chevron-right text-blue-400 ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300"
          ></i>
        </a>
      </li>

      <li>
        <a
          href="/students/leaved"
          class="group relative flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gradient-to-r hover:from-blue-50 hover:to-white dark:hover:from-gray-800 dark:hover:to-gray-700 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300"
        >
          <!-- Active Indicator -->
          <div
            class="absolute left-0 w-1 h-6 bg-[#3182ce] rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          ></div>

          <!-- Icon Container -->
          <div
            class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-100 to-white dark:from-gray-800 dark:to-gray-900 border border-blue-200 dark:border-gray-700 flex items-center justify-center mr-3 group-hover:bg-gradient-to-br group-hover:from-blue-200 group-hover:to-blue-100 dark:group-hover:from-gray-700 dark:group-hover:to-gray-800 transition-all duration-300"
          >
            <i class="fas fa-user-slash text-blue-600 text-sm"></i>
          </div>

          <span class="font-medium">Leaved Students</span>

          <!-- Hover Indicator -->
          <i
            class="fas fa-chevron-right text-blue-400 ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300"
          ></i>
        </a>
      </li>

      <!-- Divider with Label -->
      <li class="pt-4 pb-1">
        <div class="px-4">
          <div class="flex items-center">
            <div
              class="flex-1 h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent"
            ></div>
            <span
              class="px-3 text-xs font-medium text-blue-500 bg-blue-50 dark:bg-gray-800 dark:text-blue-400 rounded-full"
              >MANAGEMENT</span
            >
            <div
              class="flex-1 h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent"
            ></div>
          </div>
        </div>
      </li>

      <!-- Secondary Navigation -->
      <li>
        <a
          href="/files"
          class="group relative flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gradient-to-r hover:from-blue-50 hover:to-white dark:hover:from-gray-800 dark:hover:to-gray-700 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300"
        >
          <!-- Active Indicator -->
          <div
            class="absolute left-0 w-1 h-6 bg-[#3182ce] rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          ></div>

          <!-- Icon Container -->
          <div
            class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-100 to-white dark:from-gray-800 dark:to-gray-900 border border-blue-200 dark:border-gray-700 flex items-center justify-center mr-3 group-hover:bg-gradient-to-br group-hover:from-blue-200 group-hover:to-blue-100 dark:group-hover:from-gray-700 dark:group-hover:to-gray-800 transition-all duration-300"
          >
            <i class="fas fa-folder-open text-blue-600 text-sm"></i>
          </div>

          <span class="font-medium">File Manager</span>

          <!-- Hover Indicator -->
          <i
            class="fas fa-chevron-right text-blue-400 ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300"
          ></i>
        </a>
      </li>

      <li>
        <a
          href="/analytics"
          class="group relative flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gradient-to-r hover:from-indigo-50 hover:to-white dark:hover:from-gray-800 dark:hover:to-gray-700 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all duration-300"
        >
          <!-- Active Indicator -->
          <div
            class="absolute left-0 w-1 h-6 bg-indigo-500 rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          ></div>

          <!-- Icon Container -->
          <div
            class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-100 to-white dark:from-gray-800 dark:to-gray-900 border border-indigo-200 dark:border-gray-700 flex items-center justify-center mr-3 group-hover:bg-gradient-to-br group-hover:from-indigo-200 group-hover:to-indigo-100 dark:group-hover:from-gray-700 dark:group-hover:to-gray-800 transition-all duration-300"
          >
            <i class="fas fa-chart-line text-indigo-600 text-sm relative z-10"></i>
            <!-- Sparkle overlay -->
            <div class="absolute -top-1 -right-1 text-[8px] text-amber-500 animate-pulse"><i class="fas fa-sparkles"></i></div>
          </div>

          <span class="font-medium">Intelligent Tracking</span>

          <!-- Hover Indicator -->
          <i
            class="fas fa-chevron-right text-indigo-400 ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300"
          ></i>
        </a>
      </li>
    </ul>

    <!-- User Profile Section -->
    <div
      class="absolute bottom-0 left-0 right-0 p-3 border-t border-blue-100 dark:border-gray-800 bg-white dark:bg-gray-900"
    >
      <div class="flex items-center">
        <!-- Avatar -->
        <div
          class="w-9 h-9 rounded-xl bg-gradient-to-br from-[#63b3ed] to-[#3182ce] flex items-center justify-center mr-3"
        >
          <span class="text-white font-bold text-sm">U</span>
        </div>

        <!-- User Info -->
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-gray-900 dark:text-white truncate">
            <%= (user.first_name || 'Teacher') + ' ' + (user.last_name || '') %>
          </p>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400 border border-blue-200 dark:border-blue-800 uppercase tracking-tighter">
              <%= user.role === 'admin' ? 'Admin' : 'Teacher' %>
            </span>
            <% if (user.subscription_tier === 'PREMIUM') { %>
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400 border border-amber-200 dark:border-amber-800 flex items-center gap-1 shadow-sm">
                <i class="fas fa-crown text-[8px]"></i> PREMIUM
              </span>
            <% } else { %>
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700 uppercase tracking-tighter">FREE</span>
            <% } %>
          </div>
        </div>

        <!-- Dropdown Button -->
        <button
          id="userMenuButton"
          type="button"
          class="p-2 rounded-lg hover:bg-blue-50 dark:hover:bg-gray-800 transition-colors duration-300"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <i class="fas fa-chevron-down text-blue-400 text-xs"></i>
        </button>
      </div>

      <!-- Dropdown Menu -->
      <div
        id="user-menu"
        class="hidden mt-3 space-y-1"
        role="menu"
        aria-label="User menu"
      >
        <a
          href="/teacher/profile/"
          class="flex items-center px-3 py-2 text-sm text-gray-700 dark:text-gray-300 rounded-lg hover:bg-blue-50 dark:hover:bg-gray-800 transition-colors duration-300"
          role="menuitem"
        >
          <i class="fas fa-user-circle text-blue-500 mr-2 text-sm"></i>
          Profile
        </a>

        <a
          href="/change-password"
          class="flex items-center px-3 py-2 text-sm text-gray-700 dark:text-gray-300 rounded-lg hover:bg-blue-50 dark:hover:bg-gray-800 transition-colors duration-300"
          role="menuitem"
        >
          <i class="fas fa-cog text-blue-500 mr-2 text-sm"></i>
          Settings
        </a>

        <div class="border-t border-blue-100 dark:border-gray-800 pt-1">
          <a
            href="/logout"
            class="flex items-center px-3 py-2 text-sm text-red-600 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/30 transition-colors duration-300"
            role="menuitem"
          >
            <i class="fas fa-sign-out-alt mr-2 text-sm"></i>
            Logout
          </a>
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  /* Custom scrollbar for sidebar */
  #logo-sidebar::-webkit-scrollbar {
    width: 4px;
  }

  #logo-sidebar::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 2px;
  }

  #logo-sidebar::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #63b3ed, #3182ce);
    border-radius: 2px;
  }

  #logo-sidebar::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(to bottom, #3182ce, #2c5282);
  }

  /* Smooth transitions */
  #logo-sidebar * {
    transition: all 0.3s ease;
  }
</style>

<script src="/js/navbar.js" nonce="<%= nonce %>" defer></script>
