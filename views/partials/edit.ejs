<!-- just to load tailwincss -->
<div class="hidden bg-orange-50 text-orange-700 border-orange-200 bg-gray-50 text-gray-600 border-gray-200 bg-emerald-50 text-emerald-700 border-emerald-200"></div>

<script src="/js/confirmDelete.js?v=3"></script>
<script src="/js/generateCredentials.js"></script>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', function () {

  /* ── Panel elements ── */
  const panel       = document.getElementById('student-detail-panel');
  const panelEmpty  = document.getElementById('panel-empty');
  const panelLoad   = document.getElementById('panel-loading');
  const panelContent= document.getElementById('panel-content');
  let   activeRow   = null;

  /* ── Show loading state (only on lg+) ── */
  function showLoading() {
    if (window.innerWidth < 1024) return; // panel is desktop-only
    panelEmpty.classList.add('hidden');
    panelContent.classList.add('hidden');
    panelLoad.classList.remove('hidden');
  }

  /* ── Populate panel with student data ── */
  function populatePanel(s) {
    // Links
    document.getElementById('pc-edit-link').href     = `/student/edit/${s.school_id}`;
    document.getElementById('pc-marks-link').href    = `/student/get_marks/${s.school_id}`;
    document.getElementById('pc-report-link').href   = `/generate-report/${s.school_id}`;
    document.getElementById('pc-analytics-link').href= `/student/analytics/${s.school_id}`;

    // Photo
    const photo = document.getElementById('pc-photo');
    photo.src = `/api/student/photo/${s.school_id}`;
    photo.onerror = () => photo.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(s.name)}&background=DBEAFE&color=1E40AF&bold=true&size=56`;
    photo.alt = s.name;

    // Text fields
    document.getElementById('pc-name').textContent    = s.name;
    document.getElementById('pc-father').textContent  = `S/O ${s.father_name || '—'}`;
    document.getElementById('pc-session').textContent = s.session || '';
    document.getElementById('pc-class').textContent   = s.class || '';
    document.getElementById('pc-id').textContent      = `ID: ${s.school_id}`;
    document.getElementById('pc-roll').textContent    = s.roll || 'N/A';
    document.getElementById('pc-admission').textContent = s.admission_no || 'N/A';
    document.getElementById('pc-srn').textContent     = s.srn_no || 'N/A';
    document.getElementById('pc-dob').textContent     = s.dob ? new Date(s.dob).toLocaleDateString('en-IN') : 'N/A';
    document.getElementById('pc-mobile').textContent  = s.mobile_no || 'N/A';

    // Status badge
    const statusEl = document.getElementById('pc-status');
    const st = (s.profile_status || 'active').toLowerCase();
    statusEl.textContent = st === 'pending' ? 'Pending' : st === 'inactive' ? 'Inactive' : 'Active';

    // Show content
    panelLoad.classList.add('hidden');
    panelContent.classList.remove('hidden');
  }

  /* ── Fetch marks and render mini performance bars ── */
  async function loadMarks(studentId) {
    const barsEl = document.getElementById('pc-perf-bars');
    const noteEl = document.getElementById('pc-perf-note');
    barsEl.innerHTML = '';
    noteEl.textContent = '';

    try {
      const res = await fetch(`/marks/school/${studentId}`, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('no marks');
      const marks = await res.json();

      if (!marks || marks.length === 0) {
        barsEl.innerHTML = '<p class="text-[10px] text-gray-400 italic">No marks recorded yet.</p>';
        return;
      }

      // Group totals per term
      const termTotals = {};
      const termMax    = {};
      marks.forEach(m => {
        const t = m.term;
        if (!termTotals[t]) { termTotals[t] = 0; termMax[t] = 0; }
        const val = parseFloat(m.marks);
        const mx  = parseFloat(m.max_marks);
        if (!isNaN(val)) termTotals[t] += val;
        if (!isNaN(mx))  termMax[t]    += mx;
      });

      const termColors = { 1: '#6366f1', 2: '#0891b2', 3: '#059669' };
      const termNames  = { 1: 'Term 1', 2: 'Term 2', 3: 'Term 3' };

      Object.keys(termTotals).sort().forEach(term => {
        const total = termTotals[term];
        const max   = termMax[term] || 1;
        const pct   = Math.min(100, Math.round((total / max) * 100));
        const color = termColors[term] || '#6366f1';

        const row = document.createElement('div');
        row.innerHTML = `
          <div class="flex items-center justify-between mb-0.5">
            <span class="text-[10px] font-semibold text-gray-600 dark:text-gray-300">${termNames[term] || 'Term ' + term}</span>
            <span class="text-[10px] font-bold" style="color:${color}">${pct}% <span class="text-gray-400 font-normal">(${total}/${max})</span></span>
          </div>
          <div class="w-full bg-gray-100 dark:bg-gray-700 rounded-full h-1.5 overflow-hidden">
            <div class="h-1.5 rounded-full transition-all duration-700" style="width:${pct}%;background:${color}"></div>
          </div>`;
        barsEl.appendChild(row);
      });
    } catch (e) {
      barsEl.innerHTML = '<p class="text-[10px] text-gray-400 italic">Could not load marks.</p>';
    }
  }

  /* ── Handle row click ── */
  async function selectStudent(studentId, row) {
    // Restore previous row
    if (activeRow) {
      activeRow.classList.remove('ring-1', 'ring-blue-300', 'bg-blue-50');
    }
    // Highlight new row — soft outer ring, no inset, no dark shadow
    activeRow = row;
    row.classList.add('ring-1', 'ring-blue-300', 'bg-blue-50');

    showLoading();
    if (window.innerWidth < 1024) return; // no panel on mobile

    try {
      const res = await fetch(`/api/student/details/${studentId}`, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('fetch failed');
      const student = await res.json();
      populatePanel(student);
      loadMarks(studentId); // non-blocking
    } catch (err) {
      panelLoad.classList.add('hidden');
      panelContent.classList.add('hidden');
      panelEmpty.classList.remove('hidden');
      panelEmpty.querySelector('p').textContent = 'Error loading student.';
    }
  }

  /* ── Attach click to every student row ── */
  document.querySelectorAll('.student-row').forEach(row => {
    row.addEventListener('click', function (event) {
      // Skip if click came from checkbox cell, action cell, links, buttons, or dropdowns
      if (event.target.closest('[data-no-select]')) return;
      const id = this.getAttribute('data-student-id');
      selectStudent(id, this);
    });
  });

  /* ── Delete confirmation ── */
  document.querySelectorAll('.delete-student-form').forEach(form => {
    form.addEventListener('submit', function (event) {
      if (typeof confirmDelete === 'function') {
        if (!confirmDelete(event)) event.preventDefault();
      } else {
        if (!confirm('Are you sure you want to delete this student?')) event.preventDefault();
      }
    });
  });

});
</script>
