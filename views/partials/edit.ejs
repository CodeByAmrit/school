<div class="p-3 sm:ml-64 dark:bg-gray-900 dark:text-white min-h-screen">
  <div class="w-full h-full mt-14 dark:bg-gray-900 dark:text-white">

    <form action="/search" method="get">
      <%- include('./search.ejs') %>

      <div class="py-3 flex justify-start gap-4">
        <button id="dropdownActionButton" data-dropdown-toggle="dropdownAction"
          class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
          type="button">
          <span class="sr-only">Action button</span>
          Download
          <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
          </svg>
        </button>
        <div id="dropdownAction" class="z-50 hidden bg-white divide-y divide-gray-100 rounded-lg shadow-sm w-44 dark:bg-gray-700 dark:divide-gray-600">
          <div class="py-1">
            <a id="selected_excel_file_button" class="flex gap-4 justify-center items-center cursor-pointer px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">
              <img src="/image/excel.svg" alt="excel" width="26px" />
              Get Excel File
            </a>
          </div>
          <div class="py-1">
            <a id="generate_credentials_button" class="flex gap-4 justify-center items-center cursor-pointer px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">
              <i class="fas fa-key text-yellow-500"></i>
              Generate Credentials
            </a>
          </div>
        </div>

        <button id="dropdownActionButton2" data-dropdown-toggle="dropdownAction2"
          class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
          type="button">
          <span class="sr-only">Action button</span>
          Action
          <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
          </svg>
        </button>
        <div id="dropdownAction2" class="z-50 hidden bg-white divide-y divide-gray-100 rounded-lg shadow-sm w-44 dark:bg-gray-700 dark:divide-gray-600">
          <ul class="py-1 text-sm text-gray-700 dark:text-gray-200" aria-labelledby="dropdownActionButton2">
            <li><a href="#" id="promote-button" class="cursor-pointer block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white">Promote</a></li>
            <li><a href="#" id="demote-button" class="cursor-pointer block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white">Demote</a></li>
          </ul>
          <div class="py-1">
            <a id="selected_id_card_button" class="cursor-pointer block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">ID Card</a>
          </div>
          <div class="py-1">
            <a id="selected_Certificate_button" class="cursor-pointer block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white">Felicitation Ceremony Certificate</a>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════
           TWO-COLUMN LAYOUT (lg+): Table | Detail Panel
           On small screens: just the table, panel is hidden
      ═══════════════════════════════════════════ -->
      <div class="flex gap-4 items-start">

        <!-- ── LEFT: Student Table (max-width capped) ── -->
        <div class="flex-1 px-1 min-w-0 overflow-x-auto rounded-xl min-h-[calc(100vh-18rem)]" id="table-column">
          <table class="w-full text-sm text-left text-gray-700 border-separate border-spacing-y-1.5" id="student-table">
            <thead class="text-xs text-gray-700 uppercase bg-blue-50 dark:bg-gray-800 dark:text-gray-400 sticky top-0 z-10">
              <tr>
                <th scope="col" class="px-3 py-2.5">
                  <input type="checkbox" id="checkbox-all-search" class="w-4 h-4 text-blue-600 bg-white border-blue-300 rounded focus:ring-blue-500 focus:ring-2"/>
                  <label for="checkbox-all-search" class="sr-only">Select all</label>
                </th>
                <th scope="col" class="px-3 py-2.5">
                  <div class="flex items-center gap-1">Student <button class="text-gray-400 hover:text-gray-600"><i class="fas fa-sort text-[10px]"></i></button></div>
                </th>
                <th scope="col" class="px-3 py-2.5">Class</th>
                <th scope="col" class="px-2 py-2.5 hidden md:table-cell">Session</th>
                <th scope="col" class="px-2 py-2.5 hidden xl:table-cell">Status</th>
                <th scope="col" class="px-3 py-2.5 text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (studentlist.length > 0) { %>
              <% studentlist.forEach((student, index) => { %>
              <tr class="student-row bg-white rounded-xl hover:bg-blue-50/40 dark:bg-gray-800 dark:hover:bg-gray-700 transition-all shadow-sm border border-gray-100 dark:border-gray-700 cursor-pointer"
                  data-student-id="<%= student.school_id %>">

                <!-- Checkbox -->
                <td class="px-3 py-2" data-no-select>
                  <input type="checkbox" class="student-checkbox w-4 h-4 text-blue-600 bg-white border-blue-300 rounded focus:ring-blue-500 focus:ring-2 focus:outline-none outline-none" data-id="<%= student.school_id %>"/>
                </td>

                <!-- Student Info -->
                <td class="px-2 py-2">
                  <div class="flex items-center space-x-2.5">
                    <div class="w-9 h-9 rounded-lg overflow-hidden shadow-sm flex-shrink-0">
                      <img class="object-cover w-full h-full" src="/api/student/photo/<%= student.school_id %>" loading="lazy" alt="<%= student.name %>"
                           onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(student.name) %>&background=DBEAFE&color=1E40AF&bold=true&size=36'"/>
                    </div>
                    <div class="min-w-0">
                      <div class="font-bold text-gray-900 dark:text-white truncate text-xs"><%= student.name %></div>
                      <div class="text-[10px] text-gray-400 font-mono">ID: <%= student.school_id %></div>
                    </div>
                  </div>
                </td>

                <!-- Class -->
                <td class="px-3 py-2">
                  <span class="text-xs font-semibold text-gray-700 dark:text-gray-300 bg-blue-50 dark:bg-blue-900/30 px-2 py-0.5 rounded-md"><%= student.class %></span>
                </td>

                <!-- Session -->
                <td class="px-2 py-2 hidden md:table-cell">
                  <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400"><%= student.session %></span>
                </td>

                <!-- Status -->
                <td class="px-2 py-2 hidden xl:table-cell">
                  <%
                    const s = student.profile_status ? student.profile_status.toLowerCase() : '';
                    const statusBg = s === 'pending' ? 'bg-orange-50 text-orange-700 border-orange-200' : s === 'inactive' ? 'bg-gray-50 text-gray-600 border-gray-200' : 'bg-emerald-50 text-emerald-700 border-emerald-200';
                    const statusText = s === 'pending' ? 'Pending' : s === 'inactive' ? 'Inactive' : 'Active';
                  %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium border <%= statusBg %>">
                    <span class="w-1 h-1 rounded-full bg-current mr-1"></span><%= statusText %>
                  </span>
                </td>

                <!-- Actions -->
                <td class="px-3 py-2 text-right" data-no-select>
                  <div class="flex items-center justify-end space-x-1">
                    <a href="/student/edit/<%= student.school_id %>"
                       class="text-green-600 hover:text-green-800 p-1.5 rounded-md hover:bg-green-50 transition-colors" title="Edit Profile">
                      <i class="fas fa-edit text-xs"></i>
                    </a>
                    <div class="relative">
                      <button id="student-actions-<%= student.school_id %>"
                              data-dropdown-toggle="dropdown-<%= student.school_id %>"
                              class="text-gray-500 hover:text-gray-800 p-1.5 rounded-md hover:bg-gray-100 transition-colors"
                              type="button">
                        <i class="fas fa-ellipsis-v text-xs"></i>
                      </button>
                      <div id="dropdown-<%= student.school_id %>" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.1)] border border-gray-100 z-50 overflow-hidden dark:bg-gray-800 dark:border-gray-700">
                        <div class="px-4 py-2.5 bg-gradient-to-r from-blue-50/80 to-blue-100/30 dark:from-blue-900/20 border-b border-gray-100 dark:border-gray-700">
                          <div class="font-semibold text-gray-800 dark:text-white text-xs truncate"><%= student.name %></div>
                          <div class="text-[10px] text-gray-500">ID: <%= student.school_id %></div>
                        </div>
                        <div class="py-1">
                          <div class="px-4 py-1 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Academic</div>
                          <a href="/student/get_marks/<%= student.school_id %>" class="flex items-center px-4 py-2 text-xs text-gray-600 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/20 transition-colors">
                            <i class="fas fa-pencil-alt w-5 text-purple-500 text-center mr-2"></i><span class="font-medium">Edit Marks</span>
                          </a>
                          <a href="/student/analytics/<%= student.school_id %>" class="flex items-center px-4 py-2 text-xs text-gray-600 hover:bg-indigo-50 hover:text-indigo-700 dark:hover:bg-indigo-900/20 transition-colors">
                            <i class="fas fa-chart-line w-5 text-indigo-500 text-center mr-2"></i><span class="font-medium">Analytics</span>
                          </a>
                          <div class="px-4 py-1 text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Documents</div>
                          <a href="/generate-report/<%= student.school_id %>" class="flex items-center px-4 py-2 text-xs text-gray-600 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/20 transition-colors">
                            <i class="fas fa-file-invoice w-5 text-orange-500 text-center mr-2"></i><span class="font-medium">Report Card</span>
                          </a>
                          <a href="/generate-certificate/<%= student.school_id %>" class="flex items-center px-4 py-2 text-xs text-gray-600 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/20 transition-colors">
                            <i class="fas fa-award w-5 text-green-500 text-center mr-2"></i><span class="font-medium">Certificate</span>
                          </a>
                          <a href="/api/students/get/virual-card/<%= student.school_id %>" target="_blank" class="flex items-center px-4 py-2 text-xs text-gray-600 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/20 transition-colors">
                            <i class="fas fa-id-badge w-5 text-blue-500 text-center mr-2"></i><span class="font-medium">Virtual ID Card</span>
                          </a>
                          <div class="w-full h-px bg-gray-100 dark:bg-gray-700 my-1"></div>
                          <form id="move-to-leaved-form-<%= student.school_id %>" action="/student/mark-left/<%= student.school_id %>" method="POST" class="m-0">
                            <input type="hidden" name="reason" value="Graduated"/>
                            <button type="submit" class="flex items-center w-full text-left px-4 py-2 text-xs text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors">
                              <i class="fas fa-user-graduate w-5 text-center mr-2"></i><span class="font-medium">Mark as Left</span>
                            </button>
                          </form>
                          <form action="/delete/<%= student.school_id %>" method="POST" class="delete-student-form m-0">
                            <button type="submit" class="flex items-center w-full text-left px-4 py-2 text-xs text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                              <i class="fas fa-trash w-5 text-center mr-2"></i><span class="font-medium">Delete Student</span>
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
              <% }); %>
              <% } else { %>
              <tr>
                <td colspan="6" class="px-6 py-16 text-center">
                  <div class="flex flex-col items-center justify-center">
                    <i class="fas fa-users text-6xl text-blue-200 mb-4"></i>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">No Students Found</h3>
                    <p class="text-gray-500 text-sm mb-6">There are no student records matching your search.</p>
                    <a href="/student/new" class="bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl px-6 py-2.5 inline-flex items-center gap-2 text-sm">
                      <i class="fas fa-plus"></i> Add First Student
                    </a>
                  </div>
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- ── RIGHT: Student Detail Panel (hidden on < lg) ── -->
        <div id="student-detail-panel"
             class="hidden lg:flex flex-col w-80 xl:w-96 flex-shrink-0 sticky top-20 self-start"
             style="max-height: calc(100vh - 6rem); overflow-y: auto;">

          <!-- Empty / Hint state -->
          <div id="panel-empty" class="flex flex-col items-center justify-center h-full min-h-72 bg-white dark:bg-gray-800 rounded-2xl border border-dashed border-gray-200 dark:border-gray-700 text-center px-6 py-10">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900/30 dark:to-indigo-900/30 flex items-center justify-center mb-4">
              <i class="fas fa-mouse-pointer text-2xl text-blue-400"></i>
            </div>
            <p class="text-sm font-semibold text-gray-500 dark:text-gray-400">Select a student</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Click any row to see details here</p>
          </div>

          <!-- Loading skeleton -->
          <div id="panel-loading" class="hidden bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden animate-pulse">
            <div class="h-28 bg-gradient-to-r from-blue-200 to-indigo-200 dark:from-blue-900/40 dark:to-indigo-900/40"></div>
            <div class="p-4 space-y-3">
              <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4"></div>
              <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-1/2"></div>
              <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-2/3"></div>
              <div class="grid grid-cols-2 gap-2 pt-2">
                <div class="h-12 bg-gray-100 dark:bg-gray-700/50 rounded-lg"></div>
                <div class="h-12 bg-gray-100 dark:bg-gray-700/50 rounded-lg"></div>
                <div class="h-12 bg-gray-100 dark:bg-gray-700/50 rounded-lg"></div>
                <div class="h-12 bg-gray-100 dark:bg-gray-700/50 rounded-lg"></div>
              </div>
            </div>
          </div>

          <!-- Loaded content -->
          <div id="panel-content" class="hidden bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden shadow-sm">
            <!-- Header banner -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-4 pt-4 pb-3 relative">
              <div class="flex items-center justify-between mb-1">
                <span id="pc-session" class="text-[10px] font-semibold text-blue-200 uppercase tracking-wider"></span>
                <span id="pc-status" class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-white/20 text-white"></span>
              </div>
              <h3 id="pc-name" class="text-white font-black text-base leading-tight"></h3>
              <p id="pc-father" class="text-blue-200 text-xs mt-0.5"></p>
            </div>

            <!-- Avatar overlapping banner -->
            <div class="px-4 -mt-6 flex items-end gap-3 mb-3 pt-8">
              <div class="w-14 h-14 rounded-xl overflow-hidden border-2 border-white dark:border-gray-800 shadow-md flex-shrink-0 bg-gray-100">
                <img id="pc-photo" src="" alt="" class="w-full h-full object-cover"/>
              </div>
              <div class="pb-1">
                <span id="pc-class" class="text-xs font-bold text-gray-700 dark:text-white bg-blue-50 dark:bg-blue-900/30 px-2 py-0.5 rounded-md"></span>
                <div id="pc-id" class="text-[10px] text-gray-400 font-mono mt-0.5"></div>
              </div>
            </div>

            <!-- Info grid -->
            <div class="px-4 pb-3 grid grid-cols-2 gap-2 border-b border-gray-100 dark:border-gray-700">
              <div class="bg-gray-50 dark:bg-gray-700/40 rounded-lg p-2.5">
                <div class="text-[10px] text-gray-400 uppercase font-bold tracking-wide">Roll No</div>
                <div id="pc-roll" class="text-xs font-semibold text-gray-800 dark:text-white mt-0.5"></div>
              </div>
              <div class="bg-gray-50 dark:bg-gray-700/40 rounded-lg p-2.5">
                <div class="text-[10px] text-gray-400 uppercase font-bold tracking-wide">Admission No</div>
                <div id="pc-admission" class="text-xs font-semibold text-gray-800 dark:text-white mt-0.5"></div>
              </div>
              <div class="bg-gray-50 dark:bg-gray-700/40 rounded-lg p-2.5">
                <div class="text-[10px] text-gray-400 uppercase font-bold tracking-wide">SRN No</div>
                <div id="pc-srn" class="text-xs font-semibold text-gray-800 dark:text-white mt-0.5"></div>
              </div>
              <div class="bg-gray-50 dark:bg-gray-700/40 rounded-lg p-2.5">
                <div class="text-[10px] text-gray-400 uppercase font-bold tracking-wide">Date of Birth</div>
                <div id="pc-dob" class="text-xs font-semibold text-gray-800 dark:text-white mt-0.5"></div>
              </div>
              <div class="bg-gray-50 dark:bg-gray-700/40 rounded-lg p-2.5 col-span-2">
                <div class="text-[10px] text-gray-400 uppercase font-bold tracking-wide">Mobile</div>
                <div id="pc-mobile" class="text-xs font-semibold text-gray-800 dark:text-white mt-0.5"></div>
              </div>
            </div>

            <!-- Performance mini-bars -->
            <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700" id="pc-perf-section">
              <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Term Performance</span>
                <span class="text-[10px] text-gray-400" id="pc-perf-note"></span>
              </div>
              <div id="pc-perf-bars" class="space-y-2"></div>
            </div>

            <!-- Quick actions -->
            <div class="px-4 py-3 grid grid-cols-2 gap-2">
              <a id="pc-edit-link" href="#"
                 class="flex items-center justify-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition-all text-xs">
                <i class="fas fa-edit"></i> Edit Profile
              </a>
              <a id="pc-marks-link" href="#"
                 class="flex items-center justify-center gap-1.5 bg-purple-50 hover:bg-purple-100 dark:bg-purple-900/20 dark:hover:bg-purple-900/40 text-purple-700 dark:text-purple-300 font-semibold py-2 rounded-lg transition-all text-xs border border-purple-100 dark:border-purple-800">
                <i class="fas fa-pencil-alt"></i> Edit Marks
              </a>
              <a id="pc-report-link" href="#"
                 class="flex items-center justify-center gap-1.5 bg-orange-50 hover:bg-orange-100 dark:bg-orange-900/20 text-orange-700 dark:text-orange-300 font-semibold py-2 rounded-lg transition-all text-xs border border-orange-100 dark:border-orange-800">
                <i class="fas fa-file-invoice"></i> Report Card
              </a>
              <a id="pc-analytics-link" href="#"
                 class="flex items-center justify-center gap-1.5 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-900/20 text-indigo-700 dark:text-indigo-300 font-semibold py-2 rounded-lg transition-all text-xs border border-indigo-100 dark:border-indigo-800">
                <i class="fas fa-chart-line"></i> Analytics
              </a>
            </div>
          </div>
        </div><!-- /right panel -->

      </div><!-- /two-column -->
    </form>
  </div>
</div>

<!-- Invisible Tailwind safelist helper -->
<div class="hidden bg-orange-50 text-orange-700 border-orange-200 bg-gray-50 text-gray-600 border-gray-200 bg-emerald-50 text-emerald-700 border-emerald-200"></div>

