<div class="p-3 sm:ml-64 dark:bg-gray-900 dark:text-white">
  <div class="w-full h-full mt-14 dark:bg-gray-900 dark:text-white">

    <form action="/search" method="get">
      <%- include('./search.ejs') %>

      <!-- <p class=" my-3 text-xl">Edit Profiles</p> -->

      <div class="py-4 flex justify-start gap-4">
        <button
          id="dropdownActionButton"
          data-dropdown-toggle="dropdownAction"
          class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
          type="button"
        >
          <span class="sr-only">Action button</span>
          Download
          <svg
            class="w-2.5 h-2.5 ms-2.5"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 10 6"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 1 4 4 4-4"
            />
          </svg>
        </button>
        <!-- Dropdown menu -->
        <div
          id="dropdownAction"
          class="z-50 hidden bg-white divide-y divide-gray-100 rounded-lg shadow-sm w-44 dark:bg-gray-700 dark:divide-gray-600"
        >
          <div class="py-1">
            <a
              id="selected_excel_file_button"
              class="flex gap-4 justify-center items-center cursor-pointer px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"
            >
              <img src="/image/excel.svg" alt="excel" width="26px" />
              Get Excel File
            </a>
          </div>
          <div class="py-1">
            <a
              id="generate_credentials_button"
              class="flex gap-4 justify-center items-center cursor-pointer px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"
            >
              <i class="fas fa-key text-yellow-500"></i>
              Generate Credentials
            </a>
          </div>
        </div>

        <button
          id="dropdownActionButton2"
          data-dropdown-toggle="dropdownAction2"
          class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
          type="button"
        >
          <span class="sr-only">Action button</span>
          Action
          <svg
            class="w-2.5 h-2.5 ms-2.5"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 10 6"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 1 4 4 4-4"
            />
          </svg>
        </button>
        <!-- Dropdown menu -->
        <div
          id="dropdownAction2"
          class="z-50 hidden bg-white divide-y divide-gray-100 rounded-lg shadow-sm w-44 dark:bg-gray-700 dark:divide-gray-600"
        >
          <ul
            class="py-1 text-sm text-gray-700 dark:text-gray-200"
            aria-labelledby="dropdownActionButton2"
          >
            <li>
              <a
                href="#"
                id="promote-button"
                class="cursor-pointer block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
                >Promote</a
              >
            </li>

            <li>
              <a
                href="#"
                id="demote-button"
                class="cursor-pointer block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
                >Demote</a
              >
            </li>
          </ul>
          <div class="py-1">
            <a
              id="selected_id_card_button"
              class="cursor-pointer block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"
              >ID Card</a
            >
          </div>
          <div class="py-1">
            <a
              id="selected_Certificate_button"
              class="cursor-pointer block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"
              >Felicitation Ceremony Certificate</a
            >
          </div>
        </div>
      </div>

      <!-- Student Table -->
      <div class="overflow-x-auto m-2 rounded-xl min-h-[calc(100vh-25rem)]">
        <table
          class="w-full text-sm text-left text-gray-700 border-separate border-spacing-y-2"
          id="student-table"
        >
          <thead class="text-xs text-gray-700 uppercase bg-blue-50">
            <tr>
              <!-- Select All Checkbox -->
              <th scope="col" class="px-4 py-2">
                <div class="flex items-center">
                  <input
                    type="checkbox"
                    id="checkbox-all-search"
                    class="w-4 h-4 text-blue-600 bg-white border-blue-300 rounded focus:ring-blue-500 focus:ring-2"
                  />
                  <label for="checkbox-all-search" class="sr-only"
                    >Select all</label
                  >
                </div>
              </th>

              <!-- Student Name -->
              <th scope="col" class="px-4 py-2">
                <div class="flex items-center">
                  <span>Student</span>
                  <button class="ml-1 text-gray-400 hover:text-gray-600">
                    <i class="fas fa-sort"></i>
                  </button>
                </div>
              </th>

              <!-- Class -->
              <th scope="col" class="px-4 py-2">
                <div class="flex items-center">
                  <span>Class</span>
                  <button class="ml-1 text-gray-400 hover:text-gray-600">
                    <i class="fas fa-sort"></i>
                  </button>
                </div>
              </th>

              <!-- Session -->
              <th scope="col" class="px-2 py-2 hidden md:table-cell">
                <div class="flex items-center">
                  <span>Session</span>
                </div>
              </th>

              <!-- Status -->
              <th scope="col" class="px-2 py-2 hidden lg:table-cell">
                <div class="flex items-center">
                  <span>Status</span>
                </div>
              </th>

              <!-- Actions -->
              <th scope="col" class="px-6 py-4 text-right">
                <span>Actions</span>
              </th>
            </tr>
          </thead>

          <tbody>
            <% if (studentlist.length > 0) { %>
            <% studentlist.forEach((student, index) => { %>
            <tr
              class="bg-white rounded-xl overflow-hidden hover:bg-blue-50/30 transition-all shadow-sm border border-gray-100"
              data-student-id="<%= student.school_id %>"
            >
              <!-- Checkbox -->
              <td class="px-3 py-0">
                <input
                  type="checkbox"
                  class="student-checkbox w-4 h-4 text-blue-600 bg-white border-blue-300 rounded focus:ring-blue-500 focus:ring-2"
                  data-id="<%= student.school_id %>"
                />
              </td>

              <!-- Student Info with Avatar -->
              <td class="px-2 py-0">
                <div class="flex items-center space-x-3">
                  <div class="relative flex-shrink-0">
                    <div
                      class="w-10 h-10 rounded-lg overflow-hidden shadow-sm"
                    >
                      <img
                        class="object-cover w-full h-full"
                        src="/api/student/photo/<%= student.school_id %>"
                        loading="lazy"
                        alt="<%= student.name %>"
                      />
                    </div>
                  </div>
                  <div class="min-w-0">
                    <div class="font-bold text-gray-900 truncate text-sm">
                      <%= student.name %>
                    </div>
                    <div class="text-xs text-gray-500 truncate">
                      S/O <%= student.father_name %>
                    </div>
                    <div class="text-[10px] text-gray-400 font-mono">
                      ID: <%= student.school_id %>
                    </div>
                  </div>
                </div>
              </td>

              <!-- Class -->
              <td class="px-4 py-0">
                <div class="flex items-center">
                  <div
                    class="w-7 h-7 rounded-lg bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center mr-2"
                  >
                    <i class="fas fa-chalkboard text-blue-600 text-[10px]"></i>
                  </div>
                  <div>
                    <div class="font-semibold text-gray-800 text-xs">
                      <%= student.class %>
                    </div>
                    <div class="text-[10px] text-gray-500">
                      Sec: <%= student.section %>
                    </div>
                  </div>
                </div>
              </td>

              <!-- Session -->
              <td class="px-2 py-0 hidden md:table-cell">
                <div class="text-xs font-medium text-gray-600 bg-blue-50 px-2 py-0.5 rounded-md inline-block">
                  <%= student.session %>
                </div>
              </td>

              <!-- Status -->
              <td class="px-2 py-0 hidden lg:table-cell">
                <% 
                  let statusText; 
                  let bgClass; 
                  let textClass; 
                  let borderClass; 
                  
                  if (student.profile_status && student.profile_status.toLowerCase() === 'pending') { 
                    statusText = 'Pending'; 
                    bgClass = 'bg-orange-50'; 
                    textClass = 'text-orange-700'; 
                    borderClass = 'border-orange-200'; 
                  } else if (student.profile_status && student.profile_status.toLowerCase() === 'inactive') { 
                    statusText = 'Inactive'; 
                    bgClass = 'bg-gray-50'; 
                    textClass = 'text-gray-700'; 
                    borderClass = 'border-gray-200'; 
                  } else { 
                    statusText = 'Active'; 
                    bgClass = 'bg-emerald-50'; 
                    textClass = 'text-emerald-700'; 
                    borderClass = 'border-emerald-200'; 
                  } 
                %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= bgClass %> <%= textClass %> border <%= borderClass %>">
                  <span class="w-1 h-1 rounded-full bg-current mr-1"></span>
                  <%= statusText %>
                </span>
              </td>

              <!-- Actions -->
              <td class="px-4 py-0 text-right">
                <div class="flex items-center justify-end space-x-1 relative">
                  <!-- Quick View Button -->
                  <button
                    type="button"
                    class="quick-view-btn text-blue-600 hover:text-blue-800 p-1.5 rounded-md hover:bg-blue-50 transition-colors"
                    data-student-id="<%= student.school_id %>"
                    title="Quick View"
                  >
                    <i class="fas fa-eye text-sm"></i>
                  </button>

                  <!-- Edit Button -->
                  <a
                    href="/student/edit/<%= student.school_id %>"
                    class="text-green-600 hover:text-green-800 p-2 rounded-lg hover:bg-green-50 transition-colors"
                    title="Edit Profile"
                  >
                    <i class="fas fa-edit"></i>
                  </a>

                  <!-- More Actions Dropdown -->
                  <div class="relative">
                    <button
                      id="student-actions-<%= student.school_id %>"
                      data-dropdown-toggle="dropdown-<%= student.school_id %>"
                      class="text-gray-600 hover:text-gray-900 p-2 rounded-lg hover:bg-gray-100 transition-colors z-40"
                      type="button"
                    >
                      <i class="fas fa-ellipsis-v"></i>
                    </button>

                    <!-- Dropdown Menu -->
                    <div id="dropdown-<%= student.school_id %>" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.1)] border border-gray-100 z-50 overflow-hidden">
                      <!-- Dropdown Header -->
                      <div class="px-4 py-3 bg-gradient-to-r from-blue-50/80 to-blue-100/30 border-b border-gray-100">
                        <div class="font-semibold text-gray-800 text-sm truncate"><%= student.name %></div>
                        <div class="text-xs text-gray-500 font-medium">ID: <%= student.school_id %></div>
                      </div>

                      <!-- Dropdown Items -->
                      <div class="py-1">
                        <!-- Academic Section -->
                        <div class="px-4 py-1.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Academic</div>
                        <a href="/student/get_marks/<%= student.school_id %>" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                          <i class="fas fa-pencil-alt w-5 text-purple-500 text-center mr-2"></i>
                          <span class="font-medium">Edit Marks</span>
                        </a>
                        <a href="/student/analytics/<%= student.school_id %>" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
                          <i class="fas fa-chart-line w-5 text-indigo-500 text-center mr-2"></i>
                          <span class="font-medium">Analytics Tracker</span>
                        </a>

                        <!-- Documents Section -->
                        <div class="px-4 py-1.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Documents</div>
                        <a href="/generate-report/<%= student.school_id %>" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                          <i class="fas fa-file-invoice w-5 text-orange-500 text-center mr-2"></i>
                          <span class="font-medium">Report Card</span>
                        </a>
                        <a href="/generate-certificate/<%= student.school_id %>" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                          <i class="fas fa-award w-5 text-green-500 text-center mr-2"></i>
                          <span class="font-medium">Certificate</span>
                        </a>
                        <a href="/api/students/get/virual-card/<%= student.school_id %>" target="_blank" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                          <i class="fas fa-id-badge w-5 text-blue-500 text-center mr-2"></i>
                          <span class="font-medium">Virtual ID Card</span>
                        </a>

                        <!-- Files Section -->
                        <div class="w-full h-px bg-gray-100 my-1"></div>
                        <a href="/files/one/<%= student.school_id %>" class="flex items-center px-4 py-2 text-sm text-gray-600 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                          <i class="fas fa-folder-open w-5 text-indigo-500 text-center mr-2"></i>
                          <span class="font-medium">Manage Files</span>
                        </a>

                        <!-- Danger Zone -->
                        <div class="w-full h-px bg-red-50 my-1"></div>
                        <div class="bg-red-50/20">
                          <form id="move-to-leaved-form-<%= student.school_id %>" action="/student/mark-left/<%= student.school_id %>" method="POST" class="m-0">
                            <input type="hidden" name="reason" value="Graduated"/>
                            <button type="submit" class="flex items-center w-full text-left px-4 py-2 text-sm text-amber-600 hover:bg-amber-50 hover:text-amber-700 transition-colors">
                              <i class="fas fa-user-graduate w-5 text-center mr-2"></i>
                              <span class="font-medium">Mark as Left</span>
                            </button>
                          </form>

                          <form action="/delete/<%= student.school_id %>" method="POST" class="delete-student-form m-0">
                            <button type="submit" class="flex items-center w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors">
                              <i class="fas fa-trash w-5 text-center mr-2"></i>
                              <span class="font-medium">Delete Student</span>
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center">
                <div class="flex flex-col items-center justify-center">
                  <div class="w-24 h-24 mb-4 text-blue-300">
                    <i class="fas fa-users text-6xl"></i>
                  </div>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">
                    No Students Found
                  </h3>
                  <p class="text-gray-600 mb-6">
                    There are no student records in the database.
                  </p>
                  <a
                    href="/student/add"
                    class="btn-gradient text-white font-medium rounded-xl px-6 py-3 inline-flex items-center"
                  >
                    <i class="fas fa-plus mr-2"></i>
                    Add First Student
                  </a>
                </div>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </form>
  </div>
</div>

<div
  id="spinner"
  role="status"
  class="fixed inset-0 flex items-center justify-center bg-gray-200 bg-opacity-50 z-50 hidden"
>
  <svg
    aria-hidden="true"
    class="w-12 h-12 text-gray-200 animate-spin dark:text-gray-600 fill-blue-600"
    viewBox="0 0 100 101"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
