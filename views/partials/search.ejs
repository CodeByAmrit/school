<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 py-3">
  <!-- Name -->
  <div class="relative">
    <input
      type="text"
      id="name"
      name="name"
      placeholder=" "
      value="<%= query.name || '' %>"
      class="peer block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:text-white dark:border-gray-600 dark:focus:border-blue-500"
    />
    <label
      for="name"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-2 peer-focus:scale-75 peer-focus:-translate-y-4 peer-focus:text-blue-600 dark:peer-focus:text-blue-500 transition-all"
    >
      Name
    </label>
  </div>

  <!-- Father Name -->
  <div class="relative">
    <input
      type="text"
      id="father_name"
      name="father_name"
      value="<%= query.father_name || '' %>"
      placeholder=" "
      class="peer block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:text-white dark:border-gray-600 dark:focus:border-blue-500"
    />
    <label
      for="father_name"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-2 peer-focus:scale-75 peer-focus:-translate-y-4 peer-focus:text-blue-600 dark:peer-focus:text-blue-500 transition-all"
    >
      Father Name
    </label>
  </div>

  <!-- Mother Name -->
  <div class="relative">
    <input
      type="text"
      id="mother_name"
      name="mother_name"
      value="<%= query.mother_name || '' %>"
      placeholder=" "
      class="peer block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:text-white dark:border-gray-600 dark:focus:border-blue-500"
    />
    <label
      for="mother_name"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-2 peer-focus:scale-75 peer-focus:-translate-y-4 peer-focus:text-blue-600 dark:peer-focus:text-blue-500 transition-all"
    >
      Mother Name
    </label>
  </div>

  <!-- SRN Number -->
  <div class="relative">
    <input
      type="text"
      id="srn_no"
      name="srn_no"
      value="<%= query.srn_no || '' %>"
      placeholder=" "
      class="peer block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:text-white dark:border-gray-600 dark:focus:border-blue-500"
    />
    <label
      for="srn_no"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-2 peer-focus:scale-75 peer-focus:-translate-y-4 peer-focus:text-blue-600 dark:peer-focus:text-blue-500 transition-all"
    >
      SRN Number
    </label>
  </div>

  <!-- Roll Number -->
  <div class="relative">
    <input
      type="text"
      id="rollno"
      name="roll_no"
      value="<%= query.roll_no || '' %>"
      placeholder=" "
      class="peer block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 dark:text-white dark:border-gray-600 dark:focus:border-blue-500"
    />
    <label
      for="rollno"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0] peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-2 peer-focus:scale-75 peer-focus:-translate-y-4 peer-focus:text-blue-600 dark:peer-focus:text-blue-500 transition-all"
    >
      Roll Number
    </label>
  </div>

  <!-- Class -->
  <div class="relative">
    <select
      id="class"
      name="class"
      class="block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 focus:outline-none focus:ring-0 focus:border-blue-600 dark:bg-gray-900 dark:border-gray-600 dark:text-white"
    >
      <% const classes = ['NURSERY', 'KG', '1ST', '2ND', '3RD', '4TH', '5TH', '6TH', '7TH', '8TH', '9TH', '10TH', '11TH', '12TH']; %>
      <% classes.forEach(cls => { %>
        <option value="<%= cls %>" <%= query.class === cls ? 'selected' : '' %>><%= cls %></option>
      <% }); %>
    </select>
    <label
      for="class"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0]"
    >
      Class
    </label>
  </div>

  <!-- Session -->
  <div class="relative">
    <select
      id="session"
      name="session"
      class="block w-full px-2.5 pt-4 pb-2.5 text-sm text-gray-900 bg-transparent rounded-lg border border-gray-300 focus:outline-none focus:ring-0 focus:border-blue-600 dark:bg-gray-900 dark:border-gray-600 dark:text-white"
    >
      <% const currentYear = new Date().getFullYear(); %>
      <% const sessions = []; for(let i = 2018; i <= currentYear + 10; i++) { sessions.push(`${i}-${i+1}`); } %>
      <% sessions.forEach(sess => { %>
        <option value="<%= sess %>" <%= (query.session === sess || (!query.session && sess === '2024-2025')) ? 'selected' : '' %>><%= sess %></option>
      <% }); %>
    </select>
    <label
      for="session"
      class="absolute start-1 top-2 z-10 px-2 text-sm text-gray-500 bg-white dark:bg-gray-900 transform scale-75 -translate-y-4 origin-[0]"
    >
      Session
    </label>
  </div>

  <!-- Search Button -->
  <div class="flex items-end">
    <button
      type="submit"
      class="flex items-center justify-center gap-3 w-full px-6 py-3 text-sm font-medium text-white rounded-lg bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:from-[#3182ce] hover:to-[#63b3ed] transition-all duration-300 shadow-md hover:shadow-lg"
    >
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 20 20">
        <path
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"
        />
      </svg>
      <span class="leading-none">Search</span>
    </button>
  </div>
</div>
