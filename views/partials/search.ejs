<form action="/search" method="GET" id="search-form" class="space-y-4 py-4">
  <!-- Top Row: Unified Search & Add Button -->
  <div class="flex flex-col md:flex-row gap-3 items-center space-y-4 py-4">
    <div class="relative flex-grow w-full">
      <div class="absolute inset-y-0 start-0 flex items-center ps-4 pointer-events-none">
        <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 20 20">
          <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"/>
        </svg>
      </div>
      <input
        type="text"
        name="q"
        value="<%= query.q || '' %>"
        placeholder="Search by name, roll no, or SRN..."
        class="block w-full ps-11 pe-4 py-3 text-sm text-gray-900 border border-gray-200 rounded-xl bg-gray-50/50 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all placeholder:text-gray-400"
      />
    </div>
  </div>

  <!-- Second Row: Horizontal Filters -->
  <div class="flex flex-wrap items-center gap-3">
    <!-- Class Filter -->
    <div class="relative">
      <select
        name="class"
        id="filter-class"
        class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
      >
        <option value="">Class: All</option>
        <% const classesList = ['NURSERY', 'KG', '1ST', '2ND', '3RD', '4TH', '5TH', '6TH', '7TH', '8TH', '9TH', '10TH', '11TH', '12TH']; %>
        <% classesList.forEach(cls => { %>
          <option value="<%= cls %>" <%= query.class === cls ? 'selected' : '' %>><%= cls %></option>
        <% }); %>
      </select>
    </div>

    <!-- Session Filter -->
    <div class="relative">
      <select
        name="session"
        id="filter-session"
        class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
      >
        <option value="">Session: All</option>
        <% const cYear = new Date().getFullYear(); %>
        <% const sessList = []; for(let i = 2020; i <= cYear + 2; i++) { sessList.push(`${i}-${i+1}`); } %>
        <% sessList.forEach(sess => { %>
          <option value="<%= sess %>" <%= query.session === sess ? 'selected' : '' %>><%= sess %></option>
        <% }); %>
      </select>
      
    </div>

    <!-- Status Filter -->
    <div class="relative">
      <select
        name="reason"
        id="filter-status"
        class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
      >
        <option value="">Status: All</option>
        <option value="Active" <%= query.reason === 'Active' ? 'selected' : '' %>>Active</option>
        <option value="Graduated" <%= query.reason === 'Graduated' ? 'selected' : '' %>>Graduated</option>
        <option value="Withdrawn" <%= query.reason === 'Withdrawn' ? 'selected' : '' %>>Withdrawn</option>
      </select>
     
    </div>

    <!-- More Filters Toggle -->
    <button
      type="button"
      id="toggle-more-filters"
      class="inline-flex items-center text-gray-500 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-3 py-1.5 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
      </svg>
      More Filters
    </button>
    
    <!-- Submit Button (Hidden on larger screens as selects auto-submit) -->
    <button type="submit" class="hidden md:flex items-center justify-center p-2.5 text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-all">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <!-- Advanced Filters Section (Hidden by default) -->
  <div id="more-filters" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 p-4 bg-gray-50 border border-gray-200 rounded-xl animate-in fade-in slide-in-from-top-2">
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1 ps-1">Father's Name</label>
      <input type="text" name="father_name" value="<%= query.father_name || '' %>" placeholder="Search father's name..." class="block w-full px-3 py-2 text-sm border-gray-200 rounded-lg focus:ring-blue-500 focus:border-blue-500">
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1 ps-1">Mother's Name</label>
      <input type="text" name="mother_name" value="<%= query.mother_name || '' %>" placeholder="Search mother's name..." class="block w-full px-3 py-2 text-sm border-gray-200 rounded-lg focus:ring-blue-500 focus:border-blue-500">
    </div>
    <div class="flex items-end">
      <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-all">Apply Advanced Filters</button>
    </div>
    <div class="flex items-end">
      <button type="button" id="reset-filters" class="w-full px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-all">Reset All</button>
    </div>
  </div>

  <!-- Active Tags Row -->
  <% 
    const activeFilters = [];
    if (query.q) activeFilters.push({ key: 'q', label: `Search: ${query.q}` });
    if (query.class) activeFilters.push({ key: 'class', label: `Class: ${query.class}` });
    if (query.session) activeFilters.push({ key: 'session', label: `Session: ${query.session}` });
    if (query.reason) activeFilters.push({ key: 'reason', label: `Status: ${query.reason}` });
    if (query.father_name) activeFilters.push({ key: 'father_name', label: `Father: ${query.father_name}` });
    if (query.mother_name) activeFilters.push({ key: 'mother_name', label: `Mother: ${query.mother_name}` });
  %>

  <% if (activeFilters.length > 0) { %>
    <div class="flex flex-wrap items-center gap-2 pt-1">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wider me-1">Active:</span>
      <% activeFilters.forEach(filter => { %>
        <div class="flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 text-blue-700 text-xs font-medium rounded-full border border-blue-100 animate-in zoom-in duration-200">
          <span><%= filter.label %></span>
          <button 
            type="button" 
            data-filter-key="<%= filter.key %>"
            class="filter-tag-remove p-0.5 hover:bg-blue-200 rounded-full transition-colors"
          >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      <% }) %>
      <button 
        type="button" 
        id="clear-all-filters"
        class="text-xs text-gray-400 hover:text-red-500 underline underline-offset-4 ms-2 transition-colors"
      >
        Clear all
      </button>
    </div>
  <% } %>
</form>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('search-form');
    
    // Auto-submit on select change
    ['filter-class', 'filter-session', 'filter-status'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('change', () => form.submit());
      }
    });

    // Toggle more filters
    const toggleBtn = document.getElementById('toggle-more-filters');
    const moreFilters = document.getElementById('more-filters');
    if (toggleBtn && moreFilters) {
      toggleBtn.addEventListener('click', () => {
        moreFilters.classList.toggle('hidden');
      });
    }

    // Reset and Clear buttons
    const clearAllBtn = document.getElementById('clear-all-filters');
    const resetBtn = document.getElementById('reset-filters');
    const resetAction = () => { window.location.href = '/students'; };
    
    if (clearAllBtn) clearAllBtn.addEventListener('click', resetAction);
    if (resetBtn) resetBtn.addEventListener('click', resetAction);

    // Filter tags removal
    document.querySelectorAll('.filter-tag-remove').forEach(btn => {
      btn.addEventListener('click', function() {
        const key = this.getAttribute('data-filter-key');
        const url = new URL(window.location.href);
        url.searchParams.delete(key);
        window.location.href = url.pathname + url.search;
      });
    });
  });
</script>
