<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('meta-tags', { 
      title: typeof title !== 'undefined' ? title : undefined,
      description: typeof description !== 'undefined' ? description : undefined,
      keywords: typeof keywords !== 'undefined' ? keywords : undefined,
      noindex: typeof noindex !== 'undefined' ? noindex : false
    }) %>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "StudentTracker",
      "url": "https://edu.amritsharma.dev",
      "logo": "https://edu.amritsharma.dev/favicon.png",
      "description": "Advanced school management system for real-time student tracking and analytics.",
      "sameAs": [
        "https://twitter.com/codebyamrit"
      ]
    }
    </script>

    <script src="/js/theme.js" nonce="<%= nonce %>"></script>
    <link rel="stylesheet" href="/css/styles.css?v=<%= appVersion %>" nonce="<%= nonce %>" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Quicksand:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/icons/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/icons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/icons/favicon-16x16.png"
    />
    <link rel="manifest" href="/icons/site.webmanifest" />
    <style>
      * {
        font-family: "Quicksand" !important;
      }
      .hero-gradient {
        background: linear-gradient(
          135deg,
          #1e3a8a 0%,
          #2563eb 50%,
          #3b82f6 100%
        );
      }
      .feature-card:hover {
        transform: translateY(-5px);
        box-shadow:
          0 20px 25px -5px rgba(0, 0, 0, 0.1),
          0 10px 10px -5px rgba(0, 0, 0, 0.04);
      }
      .quicksand {
        font-family: "Quicksand", sans-serif;
      }
    </style>
  </head>

  <body class="bg-slate-50 dark:bg-gray-900 transition-colors duration-300">
    <nav
      class="fixed w-full bg-white/80 dark:bg-gray-900/80 backdrop-blur-md shadow-sm z-50 transition-colors duration-300"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16"
      >
        <a
          href="/"
          class="text-2xl font-bold bg-gradient-to-r from-[#63b3ed] to-[#3182ce] bg-clip-text text-transparent"
        >
          StudentTracker
        </a>

        <div class="hidden md:flex items-center space-x-4">
          <a
            href="/about"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium"
            >About Us</a
          >
          <a
            href="/security"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium"
            >Security</a
          >
          <a
            href="/privacy"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium"
            >Privacy</a
          >
          <a
            href="/features"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium"
            >Features</a
          >
          <a
            href="/pricing"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium"
            >Pricing</a
          >
          <a
            href="/login"
            class="text-[#3182ce] hover:text-blue-600 px-3 py-2 text-sm font-medium border rounded-md border-[#3182ce] focus:outline-none focus:ring-2 focus:ring-offset-2 hover:bg-blue-100"
            >Login</a
          >
          <a
            href="/signup"
            class="bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition duration-300"
          >
            Sign Up
          </a>

          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            type="button"
            class="p-2 text-slate-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 transition-colors duration-300"
          >
            <svg
              id="theme-toggle-dark-icon"
              class="hidden w-5 h-5"
              fill="currentColor"
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
              ></path>
            </svg>
            <svg
              id="theme-toggle-light-icon"
              class="hidden w-5 h-5"
              fill="currentColor"
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 0zM8 11a1 1 0 100-2H7a1 1 0 100 2h1z"
                fill-rule="evenodd"
                clip-rule="evenodd"
              ></path>
            </svg>
          </button>
        </div>

        <div class="md:hidden">
          <button
            data-collapse-toggle="navbar-default"
            type="button"
            class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-slate-500 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200"
            aria-controls="navbar-default"
            aria-expanded="false"
          >
            <span class="sr-only">Open main menu</span>
            <svg
              class="w-5 h-5"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 17 14"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M1 1h15M1 7h15M1 13h15"
              />
            </svg>
          </button>
        </div>
      </div>
      <div class="hidden w-full" id="navbar-default">
        <div class="px-4 pt-2 pb-6 space-y-2 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md rounded-b-2xl shadow-xl">
          <a
            href="/about"
            class="block text-slate-600 dark:text-gray-300 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >About Us</a
          >
          <a
            href="/security"
            class="block text-slate-600 dark:text-gray-300 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >Security</a
          >
          <a
            href="/privacy"
            class="block text-slate-600 dark:text-gray-300 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >Privacy</a
          >
          <a
            href="/features"
            class="block text-slate-600 dark:text-gray-300 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >Features</a
          >
          <a
            href="/pricing"
            class="block text-slate-600 dark:text-gray-300 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >Pricing</a
          >
          <hr class="border-slate-100 dark:border-gray-800 my-2" />
          <a
            href="/login"
            class="block text-slate-600 hover:text-blue-600 px-3 py-2 rounded-md text-base font-medium"
            >Login</a
          >
          <a
            href="/signup"
            class="block bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:brightness-105 text-white px-3 py-2 rounded-md text-base font-medium text-center"
            >Sign Up</a
          >
        </div>
      </div>
    </nav>
  </body>
</html>
