<link rel="stylesheet" href="/css/inputCustom.css" type="text/css">

<div class="p-3 sm:ml-64 bg-gradient-to-br from-slate-50 via-white to-blue-50/30 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 min-h-screen font-sans">
    <div class="w-full h-full dark:bg-gray-900 dark:text-white">
        <div class="container mx-auto py-4 px-2 md:px-4 pt-20">

            <!-- History Selector Card -->
            <div class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-3 mb-6 transition-all hover:shadow-md">
                <div class="flex flex-col md:flex-row items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center shadow-sm">
                            <i class="fas fa-history text-white text-md"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-gray-800 dark:text-white">Academic History</h3>
                            <p class="text-[10px] text-gray-500 dark:text-gray-400">Switch between sessions and classes</p>
                        </div>
                    </div>
                    
                    <form action="/student/get_marks/<%= student.school_id %>" method="GET" class="w-full md:w-auto">
                        <div class="relative">
                            <i class="fas fa-calendar-alt absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 dark:text-gray-500 text-xs"></i>
                            <select id="historySelector" name="session_class"
                                    class="pl-8 pr-8 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-white text-xs rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all appearance-none cursor-pointer w-full md:w-64">
                                <option value="<%= student.session %>|<%= student.class %>" <%= !viewingHistory ? 'selected' : '' %>>
                                  Current: <%= student.session %> - <%= student.class %>
                                </option>
                                <% history.forEach(h => { %>
                                    <% if (h.session !== student.session || h.class_name !== student.class) { %>
                                        <option value="<%= h.session %>|<%= h.class_name %>" <%= (viewSession === h.session && viewClassName === h.class_name) ? 'selected' : '' %>>
                                            🗂️ Archive: <%= h.session %> - <%= h.class_name %>
                                        </option>
                                    <% } %>
                                <% }); %>
                            </select>
                            <i class="fas fa-chevron-down absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 dark:text-gray-500 text-[10px] pointer-events-none"></i>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Archive Notice -->
            <% if (viewingHistory) { %>
                <div class="mb-6 p-3 flex items-center gap-3 bg-amber-50/80 dark:bg-amber-900/20 border-l-4 border-amber-500 text-amber-800 dark:text-amber-300 rounded-lg shadow-sm backdrop-blur-sm">
                    <i class="fas fa-archive text-amber-500"></i>
                    <p class="text-xs font-medium">
                        Viewing archived records for <strong>Session <%= viewSession %></strong> and <strong>Class <%= viewClassName %></strong>.
                    </p>
                </div>
            <% } %>

            <!-- Student & Performance Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
                <!-- Student Details Card -->
                <div class="bg-white dark:bg-gray-800/90 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden transition-all">
                    <div class="bg-gradient-to-r from-blue-600/90 to-indigo-700/90 px-4 py-3">
                        <div class="flex justify-between items-center">
                            <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                                <i class="fas fa-user-graduate"></i> Student Profile
                            </h2>
                            <% if (viewingHistory) { %>
                                <span class="px-2 py-0.5 bg-amber-400/20 text-amber-100 text-[9px] font-semibold rounded-full backdrop-blur-sm">ARCHIVE</span>
                            <% } else { %>
                                <span class="px-2 py-0.5 bg-green-400/20 text-green-100 text-[9px] font-semibold rounded-full backdrop-blur-sm">ACTIVE</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="p-4">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="relative">
                                <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-white dark:border-gray-700 shadow-sm flex items-center justify-center bg-gray-100 dark:bg-gray-700">
                                    <img src="/api/student/photo/<%= student.school_id %>" 
                                         onerror="this.src='https://ui-avatars.com/api/?name=<%= student.name %>&background=DBEAFE&color=1E40AF&bold=true'"
                                         class="w-full h-full object-cover">
                                </div>
                                <div class="absolute bottom-0 right-0 w-3.5 h-3.5 bg-green-500 border-2 border-white dark:border-gray-800 rounded-full"></div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-800 dark:text-white"><%= student.name %></h3>
                                <p class="text-[10px] text-gray-500 dark:text-gray-400">ID: <%= student.school_id %></p>
                            </div>
                        </div>
                        <div class="space-y-2.5 border-t border-gray-100 dark:border-gray-700 pt-3">
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400">Class (Viewing)</span>
                                <span class="text-xs font-semibold text-gray-800 dark:text-white bg-gray-50 dark:bg-gray-700 px-2 py-0.5 rounded-lg"><%= viewClassName %></span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400">Academic Session</span>
                                <span class="text-xs font-semibold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 px-2 py-0.5 rounded-lg"><%= viewSession %></span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400">Fathers Name</span>
                                <span class="text-xs font-semibold text-gray-800 dark:text-white">S/O <%= student.father_name %></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Performance Summary Card -->
                <div class="lg:col-span-2 bg-white dark:bg-gray-800/90 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
                    <div class="bg-gradient-to-r from-emerald-600/90 to-teal-700/90 px-4 py-3">
                        <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                            <i class="fas fa-chart-line"></i> Performance Overview
                        </h2>
                    </div>
                    <div class="p-4">
                        <% if (performance.length) { %>
                            <div class="overflow-x-auto">
                                <table class="w-full text-xs">
                                    <thead>
                                        <tr class="border-b border-gray-200 dark:border-gray-700">
                                            <th class="text-left py-2 px-1 font-semibold text-gray-500">Term</th>
                                            <th class="text-left py-2 px-1 font-semibold text-gray-500">Total</th>
                                            <th class="text-left py-2 px-1 font-semibold text-gray-500">%age</th>
                                            <th class="text-left py-2 px-1 font-semibold text-gray-500">Rank/Grade</th>
                                            <th class="text-left py-2 px-1 font-semibold text-gray-500">Remarks</th>
                                            <th class="text-right py-2 px-1 font-semibold text-gray-500">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-50 dark:divide-gray-700/50">
                                        <% performance.forEach(p=> { %>
                                            <form action="/action-rank/<%= p.term %>/<%= student.school_id %>" method="post">
                                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                                    <td class="py-2.5 px-1 font-semibold text-gray-900 dark:text-white">T<%= p.term %></td>
                                                    <td class="py-2.5 px-1 text-gray-700 dark:text-gray-300"><%= p.grand_total %></td>
                                                    <td class="py-2.5 px-1 text-gray-700 dark:text-gray-300 font-mono">
                                                        <%= (typeof parseFloat(p.percentage)==='number' && !isNaN(parseFloat(p.percentage))) ? parseFloat(p.percentage).toFixed(1) : '0' %>%
                                                    </td>
                                                    <td class="py-2 px-1">
                                                        <input type="text" name="grade" value="<%= rank_remarks.find(r => r.term === p.term)?.grade || '' %>"
                                                               class="w-16 px-1.5 py-1 text-xs border border-gray-200 dark:border-gray-600 rounded-md bg-gray-50/50 dark:bg-gray-700 text-gray-800 dark:text-white focus:ring-1 focus:ring-blue-500 outline-none"
                                                               placeholder="G">
                                                    </td>
                                                    <td class="py-2 px-1">
                                                        <select name="remarks"
                                                                class="w-24 px-1 py-1 text-[10px] border border-gray-200 dark:border-gray-600 rounded-md bg-gray-50/50 dark:bg-gray-700 text-gray-800 dark:text-white focus:ring-1 focus:ring-blue-500 outline-none">
                                                            <% const currentRemark = rank_remarks.find(r => r.term === p.term)?.remarks || ''; %>
                                                            <option value="<%= currentRemark %>" selected><%= currentRemark || 'Remarks' %></option>
                                                            <% if (currentRemark !== 'Excellent') { %><option value="Excellent">Excellent</option><% } %>
                                                            <% if (currentRemark !== 'Very Good') { %><option value="Very Good">Very Good</option><% } %>
                                                            <% if (currentRemark !== 'Good') { %><option value="Good">Good</option><% } %>
                                                            <% if (currentRemark !== 'Satisfactory') { %><option value="Satisfactory">Satisfactory</option><% } %>
                                                            <% if (currentRemark !== 'Needs Improvement') { %><option value="Needs Improvement">Improvement</option><% } %>
                                                        </select>
                                                    </td>
                                                    <td class="py-2 px-1 text-right">
                                                        <button type="submit" class="text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 p-1.5 rounded-lg transition-colors">
                                                            <i class="fas fa-save"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            </form>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="text-center py-4 text-gray-500 dark:text-gray-400 text-xs italic">
                                <p>No performance data available.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Marks Entry Section -->
            <div class="bg-white dark:bg-gray-800/90 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden mb-6">
                <div class="bg-gradient-to-r from-indigo-600/90 to-purple-700/90 px-4 py-3">
                    <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                        <i class="fas fa-pen-alt"></i> Subject-wise Marks Entry
                    </h2>
                </div>
                <div class="p-4">
                    <form action="/student/input-marks/<%= student.school_id %>" method="POST" id="mainMarksForm">
                        <input type="hidden" name="studentId" value="<%= student.school_id %>">
                        <input type="hidden" name="session" value="<%= viewSession %>">
                        <input type="hidden" name="class_name" value="<%= viewClassName %>">

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <% for (let term=1; term <=3; term++) { %>
                                <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden bg-white/50 dark:bg-gray-800/30 shadow-sm">
                                    <div class="bg-gray-50/50 dark:bg-gray-800/50 px-3 py-2 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
                                        <h3 class="text-xs font-semibold text-gray-800 dark:text-white flex items-center gap-1.5">
                                            <span class="w-5 h-5 rounded-full bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 flex items-center justify-center text-[10px] font-bold"><%= term %></span>
                                            Term <%= term %>
                                        </h3>
                                        <span class="text-[9px] text-gray-400 uppercase tracking-tighter">Entry Panel</span>
                                    </div>
                                    <div class="overflow-x-auto">
                                        <table class="w-full text-[11px]">
                                            <thead class="bg-gray-50/30 dark:bg-gray-800/20">
                                                <tr class="border-b border-gray-200 dark:border-gray-700 text-gray-500 uppercase tracking-tighter">
                                                    <th class="text-left py-2 px-3 font-medium">Subject</th>
                                                    <th class="text-center py-2 px-1 font-medium">Marks</th>
                                                    <th class="text-center py-2 px-1 font-medium">Max</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-50 dark:divide-gray-700/30">
                                                <% subjects.forEach(subject=> { %>
                                                    <tr class="hover:bg-gray-100/50 dark:hover:bg-gray-700/20 transition-colors">
                                                        <td class="py-2 px-3 font-medium text-gray-700 dark:text-gray-300"><%= subject %></td>
                                                        <td class="py-1 px-1">
                                                            <input type="text" name="marks[<%= term %>][<%= subject %>]"
                                                                   value="<%= marks[term] && marks[term][subject] ? marks[term][subject] : '' %>"
                                                                   class="w-14 mx-auto block px-1.5 py-1 text-center border border-gray-200 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:ring-1 focus:ring-blue-500 outline-none"
                                                                   placeholder="0">
                                                        </td>
                                                        <td class="py-1 px-1">
                                                            <% 
                                                                let maxVal = maxMarks[term] && (maxMarks[term][subject] !== undefined) ? maxMarks[term][subject] : '';
                                                                let displayMax = maxVal;
                                                                if (maxVal === 0 || maxVal === '0') {
                                                                    displayMax = (subject === 'GENERAL KNOWLEDGE') ? 'NA' : 'GR';
                                                                } else if (maxVal === '') {
                                                                    displayMax = '100';
                                                                }
                                                            %>
                                                            <input type="text" name="maxMarks[<%= term %>][<%= subject %>]"
                                                                   value="<%= displayMax %>"
                                                                   class="w-10 mx-auto block px-1 py-1 text-center text-[9px] font-semibold text-gray-400 bg-gray-50 dark:bg-gray-900 border-none rounded <%= (maxMarks[term] && (maxMarks[term][subject] !== undefined)) ? 'opacity-70' : '' %>"
                                                                   readonly>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <div class="flex justify-center mt-6">
                            <button type="submit" class="group relative flex items-center justify-center gap-3 px-4 py-3 text-sm font-medium text-white rounded-xl bg-gradient-to-br from-[#63b3ed] to-[#3182ce] hover:from-[#3182ce] hover:to-[#63b3ed] transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-[1.02] transform">
                                <i class="fas fa-save text-xs"></i> Save All Marks
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Attendance & Status Card -->
            <div class="bg-white dark:bg-gray-800/90 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden mb-12">
                <div class="bg-gradient-to-r from-amber-600/90 to-orange-600/90 px-4 py-3">
                    <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                        <i class="fas fa-calendar-check"></i> Attendance & Promotion Status
                    </h2>
                </div>
                <div class="p-4">
                    <form action="/student/attendance-status/<%= student.school_id %>" method="POST" class="flex flex-col md:flex-row gap-4 items-end">
                        <input type="hidden" name="studentId" value="<%= student.school_id %>">
                        <div class="flex-1 w-full">
                            <label class="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Attendance</label>
                            <div class="relative">
                                <input type="text" name="attendance" 
                                       value="<%= student_attendance_status ? student_attendance_status.attendance : 0 %>"
                                       class="w-full px-4 py-2 text-sm border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50/50 dark:bg-gray-700 text-gray-800 dark:text-white focus:ring-1 focus:ring-amber-500 outline-none transition-all"
                                       placeholder="Attendance %">
                            </div>
                        </div>
                        <div class="flex-1 w-full">
                            <label class="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Status</label>
                            <select name="status"
                                    class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50/50 dark:bg-gray-700 text-gray-800 dark:text-white focus:ring-1 focus:ring-amber-500 outline-none">
                                <option value="pending" <%=student_attendance_status && student_attendance_status.status==='pending' ? 'selected' : '' %>>Pending</option>
                                <option value="passed" <%=student_attendance_status && student_attendance_status.status==='passed' ? 'selected' : '' %>>Passed</option>
                                <option value="promoted" <%=student_attendance_status && student_attendance_status.status==='promoted' ? 'selected' : '' %>>Promoted</option>
                                <option value="fail" <%=student_attendance_status && student_attendance_status.status==='fail' ? 'selected' : '' %>>Fail</option>
                            </select>
                        </div>
                        <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-semibold px-8 py-2 rounded-xl shadow-md transition-all text-sm whitespace-nowrap">
                            <i class="fas fa-check-circle mr-1"></i> Update
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
    (function() {
        const historySelector = document.getElementById('historySelector');
        if (historySelector) {
            historySelector.addEventListener('change', function() {
                const val = this.value.split('|');
                if (val.length === 2) {
                    window.location.href = `/student/get_marks/<%= student.school_id %>?session=${encodeURIComponent(val[0])}&class_name=${encodeURIComponent(val[1])}`;
                }
            });
        }
    })();
</script>
