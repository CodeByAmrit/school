<%- include('partials/header.ejs', {title: "Features - StudentTracker"}) %>
<%- include('partials/guestNavbar.ejs') %>

<!-- Hero Section -->
<section
  class="relative pt-24 pb-20 text-white z-20 bg-white dark:bg-gray-900 transition-colors duration-300"
>
  <div
    class="absolute inset-0 z-0 bg-gradient-to-br from-[#63b3ed] to-[#3182ce] py-20 -top-10"
  ></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
      Empower Your School with <br />
      <span class="text-blue-100">Cutting-Edge Features</span>
    </h1>
    <p
      class="text-lg md:text-xl text-blue-50 max-w-2xl mx-auto mb-10 opacity-90"
    >
      From AI-driven insights to automated academic reporting, StudentTracker
      provides everything you need to manage your institution efficiently.
    </p>
  </div>
</section>

<!-- Detailed Features Grid -->
<section
  class="py-16 sm:py-24 bg-white dark:bg-gray-900 transition-colors duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Feature 1: Student Management -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img
            src="/animate/family.gif"
            alt="Student Management"
            class="w-10 h-10"
          />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          Complete Student Lifecycle
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Manage everything from registration to graduation. Track attendance,
          disciplinary records, and health data in one secure location.
        </p>
      </div>

      <!-- Feature 2: Automated Grading -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img
            src="/animate/score.gif"
            alt="Automated Grading"
            class="w-10 h-10"
          />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          Automated Gradebooks
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Say goodbye to manual calculations. Our system automatically computes
          averages, ranks, and percentages for entire classes in seconds.
        </p>
      </div>

      <!-- Feature 3: AI Assistant -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img
            src="/animate/neural-network.gif"
            alt="AI Assistant"
            class="w-10 h-10"
          />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          AI Teacher Assistant
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Integrated Gemini AI helps teachers generate lesson plans, quiz
          questions, and personalized feedback for students effortlessly.
        </p>
      </div>

      <!-- Feature 4: Academic Reporting -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img src="/animate/report.gif" alt="Reporting" class="w-10 h-10" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          Professional Reporting
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Generate beautiful, print-ready report cards and certificates with a
          single click. Fully customizable templates for your school's brand.
        </p>
      </div>

      <!-- Feature 5: Performance Analytics -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img
            src="/animate/data-analytics.gif"
            alt="Analytics"
            class="w-10 h-10"
          />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          Visual Analytics
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Interactive dashboards show school-wide and individual performance
          trends, helping you identify students who need extra support.
        </p>
      </div>

      <!-- Feature 6: Secure Records -->
      <div
        class="bg-gray-50 dark:bg-gray-800 p-8 rounded-2xl border border-blue-50 dark:border-gray-700 hover:shadow-lg transition-all duration-300"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mb-6"
        >
          <img src="/animate/database.gif" alt="Security" class="w-10 h-10" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
          Cloud Data Security
        </h3>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
          Your data is encrypted and backed up daily. Manage student privacy
          with granular access controls for teachers and staff.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Call to Action -->
<section class="py-16 bg-blue-600 dark:bg-blue-700 text-white text-center">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6">Ready to Transform Your School?</h2>
    <p class="text-xl mb-8 opacity-90">
      Join hundreds of institutions using StudentTracker to build the future of
      education.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a
        href="/signup"
        class="bg-white text-blue-600 px-8 py-3 rounded-lg font-bold hover:bg-blue-50 transition-colors"
        >Start Free Trial</a
      >
      <a
        href="/pricing"
        class="border border-white text-white px-8 py-3 rounded-lg font-bold hover:bg-white/10 transition-colors"
        >View Pricing</a
      >
    </div>
  </div>
</section>

<%- include('partials/land_footer') %>
